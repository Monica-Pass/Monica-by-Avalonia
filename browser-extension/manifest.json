{
  "manifest_version": 3,
  "name": "Monica Password Autofill",
  "version": "1.0.0",
  "description": "Securely fills credentials from the Monica desktop vault.",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
