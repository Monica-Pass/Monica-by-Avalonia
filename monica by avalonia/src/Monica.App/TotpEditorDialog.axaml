<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.TotpEditorDialog"
             x:DataType="vm:TotpEditorViewModel"
             mc:Ignorable="d"
             d:DesignWidth="480"
             d:DesignHeight="560">
    <UserControl.Styles>
        <Style Selector="TextBox"><Setter Property="MinHeight" Value="40" /></Style>
        <Style Selector="ComboBox"><Setter Property="MinHeight" Value="40" /></Style>
        <Style Selector="TextBlock.totpEditorLabel"><Setter Property="FontSize" Value="12" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" /></Style>
    </UserControl.Styles>
    <ScrollViewer x:Name="TotpEditorFormScrollViewer" MaxHeight="560">
        <StackPanel x:Name="TotpEditorPrimaryForm" Width="440" Spacing="12">
            <StackPanel Spacing="6"><TextBlock Classes="totpEditorLabel" Text="{Binding L.PasswordTitle}" /><TextBox Text="{Binding Title}" PlaceholderText="{Binding L.PasswordTitle}" /></StackPanel>
            <StackPanel Spacing="6">
                <TextBlock Classes="totpEditorLabel" Text="{Binding L.Category}" />
                <ComboBox x:Name="TotpCategoryPicker"
                          ItemsSource="{Binding CategoryOptions}"
                          SelectedItem="{Binding SelectedCategory}"
                          AutomationProperties.Name="{Binding L.Category}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PasswordCategoryChoice">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="{Binding Indent}" ToolTip.Tip="{Binding FullPath}">
                                <TextBlock Text="{Binding FolderDisplayName}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{Binding ParentPath}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="170" />
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            <StackPanel Spacing="6"><TextBlock Classes="totpEditorLabel" Text="{Binding L.TotpSecret}" /><TextBox x:Name="TotpSecretInput" Text="{Binding Secret}" PlaceholderText="{Binding L.TotpSecret}" /></StackPanel>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <TextBox Text="{Binding Issuer}" PlaceholderText="{Binding L.Issuer}" />
                <TextBox Grid.Column="1" Text="{Binding AccountName}" PlaceholderText="{Binding L.Account}" />
            </Grid>
            <TextBox Text="{Binding Notes}" PlaceholderText="{Binding L.Notes}" AcceptsReturn="True" MinHeight="74" TextWrapping="Wrap" />
            <CheckBox Content="{Binding L.Favorite}" IsChecked="{Binding IsFavorite}" />

            <Expander x:Name="TotpAdvancedOptionsExpander" Header="{Binding L.AdvancedTotpOptions}" IsExpanded="False">
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10" Margin="0,10,0,0">
                    <ComboBox ItemsSource="{Binding OtpTypeOptions}"
                              SelectedItem="{Binding SelectedOtpType}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TotpChoice">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding AlgorithmOptions}"
                              SelectedItem="{Binding SelectedAlgorithm}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TotpChoice">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <NumericUpDown Grid.Row="1" Value="{Binding Period}" Minimum="10" Maximum="120" Increment="5" IsVisible="{Binding IsTimeBased}" />
                    <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding Digits}" Minimum="4" Maximum="10" Increment="1" IsVisible="{Binding UsesDigits}" />
                    <NumericUpDown Grid.Row="2" Value="{Binding Counter}" Minimum="0" Increment="1" IsVisible="{Binding IsCounterBased}" />
                </Grid>
            </Expander>

            <TextBlock Text="{Binding L.TotpSecretHint}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
            <TextBlock Text="{Binding ValidationMessage}" Foreground="{DynamicResource SystemFillColorCriticalBrush}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
