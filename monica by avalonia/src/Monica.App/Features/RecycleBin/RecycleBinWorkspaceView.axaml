<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:local="using:Monica.App"
             xmlns:models="using:Monica.Core.Models"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.RecycleBin.RecycleBinWorkspaceView"
             x:Name="RecycleBinWorkspaceRoot"
             x:DataType="vm:MainWindowViewModel">
<UserControl.Styles>
    <StyleInclude Source="/Features/RecycleBin/RecycleBinStyles.axaml" />
</UserControl.Styles>
<Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsRecycleBin}}" RowDefinitions="Auto,*" HorizontalAlignment="Stretch" ClipToBounds="True">
    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
        <Grid x:Name="RecycleBinHeaderGrid" ColumnDefinitions="*,320,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" MinHeight="56">
            <StackPanel MinWidth="0" VerticalAlignment="Center">
                <TextBlock Classes="workspacePageTitle" Text="{Binding L.DeletedPasswords}" />
                <TextBlock Text="{Binding DeletedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <Grid x:Name="RecycleBinSearchRegion" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="6" VerticalAlignment="Center">
                <TextBox x:Name="RecycleBinSearchBox" PlaceholderText="{Binding L.Search}" Text="{Binding RecycleBinSearchText}" AutomationProperties.Name="{Binding L.Search}" />
                <Button x:Name="RecycleBinSearchClearButton" Grid.Column="1" Classes="workspaceCommand" Command="{Binding ClearRecycleBinSearchCommand}" IsVisible="{Binding HasRecycleBinSearchText}" ToolTip.Tip="{Binding L[Clear]}" AutomationProperties.Name="{Binding L[Clear]}" Width="36" Height="36" Padding="0">
                    <ic:FluentIcon Icon="Dismiss" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
            </Grid>
            <StackPanel x:Name="RecycleBinHeaderCommands" Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="RecycleBinPageMenuButton"
                        Classes="workspaceCommand"
                        ToolTip.Tip="{Binding L.MoreOptions}"
                        AutomationProperties.Name="{Binding L.MoreOptions}"
                        Width="40"
                        Height="40"
                        Padding="0">
                    <ic:FluentIcon Icon="MoreHorizontal" FontSize="18" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem x:Name="OpenPasswordsFromRecycleBinMenuItem" Header="{Binding L.Passwords}" Command="{Binding SelectSectionCommand}" CommandParameter="Passwords">
                                <MenuItem.Icon><ic:FluentIcon Icon="Key" FontSize="16" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem x:Name="OpenArchiveFromRecycleBinMenuItem" Header="{Binding L.Archive}" Command="{Binding SelectSectionCommand}" CommandParameter="Archive">
                                <MenuItem.Icon><ic:FluentIcon Icon="Archive" FontSize="16" /></MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem x:Name="EmptyRecycleBinMenuItem" Header="{Binding L.EmptyRecycleBin}" Command="{Binding EmptyRecycleBinCommand}" IsEnabled="{Binding HasDeletedPasswords}">
                                <MenuItem.Icon><ic:FluentIcon Icon="DeleteDismiss" FontSize="16" /></MenuItem.Icon>
                            </MenuItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>
    </Border>

    <Grid x:Name="RecycleBinMasterDetailGrid" Grid.Row="1" ColumnDefinitions="300,*" MinWidth="0">
        <Border x:Name="RecycleBinListRegion" Classes="recycleFilterRail" ClipToBounds="True">
            <Grid RowDefinitions="Auto,Auto,*">
                <Grid Margin="14,12,14,8" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <StackPanel Spacing="3">
                        <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.DeletedPasswords}" />
                        <TextBlock Text="{Binding DeletedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                    <CheckBox x:Name="RecycleBinSelectAllCheckBox"
                              Grid.Column="1"
                              IsChecked="{Binding AreAllFilteredDeletedPasswordsSelected}"
                              IsEnabled="{Binding HasFilteredDeletedPasswords}"
                              ToolTip.Tip="{Binding SelectAllVisiblePasswordsText}"
                              AutomationProperties.Name="{Binding SelectAllVisiblePasswordsText}"
                              VerticalAlignment="Center" />
                </Grid>
                <Border x:Name="RecycleBinSelectionBar"
                        Grid.Row="1"
                        IsVisible="{Binding HasSelectedDeletedPasswords}"
                        Margin="0"
                        Padding="14,8"
                        CornerRadius="0"
                        Background="{DynamicResource LayerFillColorSubtleBrush}"
                        BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Text="{Binding SelectedDeletedPasswordCountText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button x:Name="RestoreSelectedPasswordsButton"
                                    Classes="workspacePrimaryCommand"
                                    Command="{Binding RestoreSelectedDeletedPasswordsCommand}"
                                    ToolTip.Tip="{Binding L.RestorePassword}"
                                    AutomationProperties.Name="{Binding L.RestorePassword}"
                                    Padding="8,4">
                                <ic:FluentIcon Icon="ArrowUndo" FontSize="16" />
                            </Button>
                            <Button x:Name="DeleteSelectedPasswordsPermanentlyButton"
                                    Classes="workspaceCommand"
                                    Command="{Binding DeleteSelectedDeletedPasswordsPermanentlyCommand}"
                                    ToolTip.Tip="{Binding L.DeletePermanently}"
                                    AutomationProperties.Name="{Binding L.DeletePermanently}"
                                    Padding="8,4">
                                <ic:FluentIcon Icon="Delete" FontSize="16" />
                            </Button>
                            <Button x:Name="ClearRecycleBinSelectionButton"
                                    Classes="workspaceCommand"
                                    Command="{Binding ClearDeletedPasswordSelectionCommand}"
                                    ToolTip.Tip="{Binding L.Cancel}"
                                    AutomationProperties.Name="{Binding L.Cancel}"
                                    Padding="8,4">
                                <ic:FluentIcon Icon="Dismiss" FontSize="16" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
                <Grid Grid.Row="2">
                    <StackPanel IsVisible="{Binding !HasFilteredDeletedPasswords}" HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="10" Margin="24" Width="240">
                        <ic:FluentIcon Icon="Delete" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding DeletedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding RecycleBinEmptyStateText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                        <Button x:Name="EmptyRecycleBinClearSearchButton" Classes="workspaceCommand" Command="{Binding ClearRecycleBinSearchCommand}" IsVisible="{Binding ShowClearRecycleBinSearchInEmptyState}" ToolTip.Tip="{Binding L[Clear]}" AutomationProperties.Name="{Binding L[Clear]}" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="Dismiss" FontSize="12" /><TextBlock Text="{Binding L[Clear]}" /></StackPanel>
                        </Button>
                        <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Passwords" ToolTip.Tip="{Binding L.Passwords}" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="Key" FontSize="16" />
                                <TextBlock Text="{Binding L.Passwords}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <ListBox x:Name="RecycleBinPasswordList" Classes="recycleQueueList" ItemsSource="{Binding FilteredDeletedPasswords}" SelectedItem="{Binding SelectedDeletedPassword}" IsVisible="{Binding HasFilteredDeletedPasswords}" SelectionMode="Single" AutomationProperties.Name="{Binding L.RecycleBin}" Margin="8,0,8,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:PasswordEntry">
                                <Border Classes="recycleQueueRow">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{Binding #RecycleBinWorkspaceRoot.DataContext.L.RestorePassword}" Command="{Binding #RecycleBinWorkspaceRoot.DataContext.RestorePasswordCommand}" CommandParameter="{Binding}" />
                                            <MenuItem Header="{Binding #RecycleBinWorkspaceRoot.DataContext.L.DeletePermanently}" Command="{Binding #RecycleBinWorkspaceRoot.DataContext.DeletePasswordPermanentlyCommand}" CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                        <Button Classes="recycleQueueRowButton"
                                                Command="{Binding #RecycleBinWorkspaceRoot.DataContext.ShowDeletedPasswordDetailsCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{Binding Title}"
                                                AutomationProperties.Name="{Binding Title}">
                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="2">
                                                <Border Grid.RowSpan="3" Width="38" Height="38" CornerRadius="19" Background="{DynamicResource AccentFillColorSecondaryBrush}" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding AvatarText}" Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Username}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                            </Grid>
                                        </Button>
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding IsSelected}"
                                                  ToolTip.Tip="{Binding #RecycleBinWorkspaceRoot.DataContext.SelectPasswordItemsText}"
                                                  AutomationProperties.Name="{Binding #RecycleBinWorkspaceRoot.DataContext.SelectPasswordItemsText}"
                                                  VerticalAlignment="Center"
                                                  Margin="4" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="RecycleBinDetailRegion" Grid.Column="1" Classes="recycleInspector" Padding="24" MinWidth="0" Focusable="True">
            <Grid>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" IsVisible="{Binding HasSelectedDeletedPassword}">
                <StackPanel Spacing="18">
                    <Button x:Name="BackToRecycleBinListButton" Classes="workspaceCommand" Command="{Binding CloseDeletedPasswordDetailsCommand}" ToolTip.Tip="{Binding L[Back]}" AutomationProperties.Name="{Binding L[Back]}" HorizontalAlignment="Left" IsVisible="False">
                        <StackPanel Orientation="Horizontal" Spacing="6"><ic:FluentIcon Icon="ArrowLeft" FontSize="16" /><TextBlock Text="{Binding L[Back]}" /></StackPanel>
                    </Button>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Border Width="54" Height="54" CornerRadius="27" Background="{DynamicResource AccentFillColorSecondaryBrush}">
                            <TextBlock Text="{Binding SelectedDeletedPassword.AvatarText}" Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" FontWeight="SemiBold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedDeletedPassword.Title}" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SelectedDeletedPassword.Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                        <Button x:Name="RecycleBinDetailPrimaryActionButton" Classes="workspacePrimaryCommand" Command="{Binding RestorePasswordCommand}" CommandParameter="{Binding SelectedDeletedPassword}" ToolTip.Tip="{Binding L.RestorePassword}" AutomationProperties.Name="{Binding L.RestorePassword}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="ArrowUndo" FontSize="18" />
                                <TextBlock Text="{Binding L.RestorePassword}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="RecycleBinDetailMenuButton"
                                Classes="workspaceCommand"
                                ToolTip.Tip="{Binding L.MoreOptions}"
                                AutomationProperties.Name="{Binding L.MoreOptions}"
                                Width="40"
                                Height="40"
                                Padding="0">
                            <ic:FluentIcon Icon="MoreHorizontal" FontSize="18" />
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem x:Name="OpenDeletedPasswordDetailsMenuItem" Header="{Binding L.PasswordDetails}" Command="{Binding ShowPasswordDetailsCommand}" CommandParameter="{Binding SelectedDeletedPassword}">
                                        <MenuItem.Icon><ic:FluentIcon Icon="Info" FontSize="16" /></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem x:Name="DeletePasswordPermanentlyMenuItem" Header="{Binding L.DeletePermanently}" Command="{Binding DeletePasswordPermanentlyCommand}" CommandParameter="{Binding SelectedDeletedPassword}">
                                        <MenuItem.Icon><ic:FluentIcon Icon="DeleteDismiss" FontSize="16" /></MenuItem.Icon>
                                    </MenuItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                    <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="14">
                        <TextBlock Classes="workspaceDetailLabel" Text="{Binding L.Username}" />
                        <TextBlock Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedDeletedPassword.Username}" />
                        <TextBlock Grid.Row="1" Classes="workspaceDetailLabel" Text="{Binding L.Website}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedDeletedPassword.Website}" />
                        <TextBlock Grid.Row="2" Classes="workspaceDetailLabel" Text="{Binding L.CreatedAt}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedDeletedPassword.CreatedAt, StringFormat='{}{0:g}'}" />
                        <TextBlock Grid.Row="3" Classes="workspaceDetailLabel" Text="{Binding L.UpdatedAt}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedDeletedPassword.UpdatedAt, StringFormat='{}{0:g}'}" />
                        <TextBlock Grid.Row="4" Classes="workspaceDetailLabel" Text="{Binding L.RecycleBin}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedDeletedPassword.DeletedAt, StringFormat='{}{0:g}'}" />
                    </Grid>
                </StackPanel>
                </ScrollViewer>
                <StackPanel IsVisible="{Binding !HasSelectedDeletedPassword}" Spacing="10" Width="260" Margin="24" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <ic:FluentIcon Icon="Delete" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding DeletedPasswordCountText}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Grid>
</UserControl>
