<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ic="using:FluentIcons.Avalonia" xmlns:local="using:Monica.App" xmlns:settings="using:Monica.App.Features.Settings" xmlns:vm="using:Monica.App.ViewModels" x:Class="Monica.App.Features.Settings.SettingsWorkspaceView" x:DataType="vm:MainWindowViewModel">
    <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsSettings}}" RowDefinitions="Auto,*" MaxWidth="1080" HorizontalAlignment="Stretch" ClipToBounds="True">
        <Border Classes="workspacePageHeader">
            <StackPanel Spacing="3">
                <TextBlock Classes="workspacePageTitle" Text="{Binding L.Settings}" />
                <TextBlock Classes="workspacePageSubtitle" Text="{Binding L.SettingsSubtitle}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
        <Grid x:Name="SettingsWorkspaceLayoutGrid" Grid.Row="1" ColumnDefinitions="260,*" RowDefinitions="*" ColumnSpacing="16" RowSpacing="12" MinWidth="0">
            <Border x:Name="SettingsSidebarRegion" Classes="workspaceSidebar" Padding="14" ClipToBounds="True">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.Settings}" Margin="2,0,0,4" />
                        <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsGeneralSelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="General">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ic:FluentIcon Icon="Settings" FontSize="17" />
                                <TextBlock Text="{Binding L.General}" />
                            </StackPanel>
                        </Button>
                        <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsSecuritySelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="Security">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ic:FluentIcon Icon="Shield" FontSize="17" />
                                <TextBlock Text="{Binding L.Security}" />
                            </StackPanel>
                        </Button>
                        <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsSecurityRecoverySelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="SecurityRecovery">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ic:FluentIcon Icon="Key" FontSize="17" />
                                <TextBlock Text="{Binding SecurityRecoveryTitle}" />
                            </StackPanel>
                        </Button>
                        <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsDataSelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="Data">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ic:FluentIcon Icon="Save" FontSize="17" />
                                <TextBlock Text="{Binding L.DataManagement}" />
                            </StackPanel>
                        </Button>
                        <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsDesktopSelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="Desktop">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ic:FluentIcon Icon="Desktop" FontSize="17" />
                                <TextBlock Text="{Binding L.Desktop}" />
                            </StackPanel>
                        </Button>
                        <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsIntegrationsSelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="Integrations">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ic:FluentIcon Icon="Link" FontSize="17" />
                                <TextBlock Text="{Binding PlatformIntegrationsTitle}" />
                            </StackPanel>
                        </Button>
                        <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsAboutSelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="About">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ic:FluentIcon Icon="Info" FontSize="17" />
                                <TextBlock Text="{Binding AboutTitle}" />
                            </StackPanel>
                        </Button>
                        <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSettingsDangerSelected}" Command="{Binding SelectSettingsPageCommand}" CommandParameter="Danger">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <ic:FluentIcon Icon="Delete" FontSize="17" />
                                <TextBlock Text="{Binding DangerZoneTitle}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <ScrollViewer x:Name="SettingsContentRegion" Grid.Column="1" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                <StackPanel Spacing="14" MaxWidth="760" HorizontalAlignment="Stretch">
                    <settings:SettingsGeneralView />
                    <settings:SettingsSecurityView />
                    <settings:SettingsRecoveryView />
                    <settings:SettingsDataView />
                    <settings:SettingsDesktopView />
                    <settings:SettingsIntegrationsView />
                    <settings:SettingsAboutView />
                    <settings:SettingsDangerView />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>