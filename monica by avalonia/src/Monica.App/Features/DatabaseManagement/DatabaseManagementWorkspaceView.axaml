<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:local="using:Monica.App"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.DatabaseManagement.DatabaseManagementWorkspaceView"
             x:Name="DatabaseManagementRoot"
             x:DataType="vm:MainWindowViewModel">
<Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsDatabaseManagement}}"
      RowDefinitions="Auto,*"
      HorizontalAlignment="Stretch"
      ClipToBounds="True">
        <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                <TextBlock Classes="workspacePageTitle" Text="{Binding L.DatabaseManagement}" />
                <TextBlock Grid.Row="1" Classes="workspacePageSubtitle" Text="{Binding VaultSourceCountText}" MaxWidth="720" HorizontalAlignment="Left" />
                <WrapPanel Grid.Column="1" Grid.RowSpan="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Classes="workspaceCommand" Command="{Binding LoadCommand}" Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                            <TextBlock Text="{Binding L.Refresh}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="workspacePrimaryCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Mdbx" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:FluentIcon Icon="Database" FontSize="18" />
                            <TextBlock Text="{Binding L.MdbxVaults}" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="360,*" ColumnSpacing="14" MinWidth="0">
            <Border Classes="databaseSourceRail" ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <Grid Margin="14,12,14,8" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <StackPanel Spacing="3">
                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.RegisteredDatabases}" />
                            <TextBlock Text="{Binding VaultSourceCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                        <Button Grid.Column="1" Classes="workspaceCommand" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}" AutomationProperties.Name="{Binding L.Refresh}" Width="34" Height="34" Padding="0">
                            <ic:FluentIcon Icon="ArrowClockwise" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1">
                        <StackPanel IsVisible="{Binding !HasVaultSources}" HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="10" Margin="24" Width="240">
                            <ic:FluentIcon Icon="Database" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding L.DatabaseSourcesEmptyHint}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                            <Button Classes="workspaceCommand" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:FluentIcon Icon="ArrowClockwise" FontSize="16" />
                                    <TextBlock Text="{Binding L.Refresh}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                    <ListBox Classes="databaseSourceList" ItemsSource="{Binding VaultSources}" SelectedItem="{Binding SelectedVaultSource}" IsVisible="{Binding HasVaultSources}" SelectionMode="Single" Margin="8,0,8,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:VaultSourceDisplayItem">
                                <Border Classes="databaseSourceRow">
                                    <Button Classes="databaseSourceButton"
                                            Command="{Binding #DatabaseManagementRoot.DataContext.ShowVaultSourceDetailsCommand}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{Binding DisplayName}">
                                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="3">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="1" Grid.RowSpan="2" Classes="workspaceStatusChip" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Kind}" FontSize="12" />
                                            </Border>
                                            <TextBlock Grid.Row="1" Text="{Binding LocalPath}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                            <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding SyncStatus}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                        </Grid>
                                    </Button>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <ScrollViewer x:Name="DatabaseManagementScrollViewer" Grid.Column="1" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                <StackPanel Spacing="14" HorizontalAlignment="Stretch">
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                        <Button Classes="databasePivotButton" Classes.accent="{Binding IsDatabaseSourceSelected}" Command="{Binding SelectDatabaseManagementPageCommand}" CommandParameter="Source">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="Database" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding L.RegisteredDatabases}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Classes="databasePivotButton" Classes.accent="{Binding IsDatabaseOverviewSelected}" Command="{Binding SelectDatabaseManagementPageCommand}" CommandParameter="Overview">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="Info" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding L.LocalDatabase}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Classes="databasePivotButton" Classes.accent="{Binding IsDatabaseCloudSelected}" Command="{Binding SelectDatabaseManagementPageCommand}" CommandParameter="Cloud">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="Cloud" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding L.CloudAndLocalVaults}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" Classes="databasePivotButton" Classes.accent="{Binding IsDatabaseCapabilitiesSelected}" Command="{Binding SelectDatabaseManagementPageCommand}" CommandParameter="Capabilities">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="Link" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding L.FeatureParityMap}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Classes="databaseWorkbench" Padding="20" MinWidth="0" IsVisible="{Binding IsDatabaseSourceSelected}">
                        <Grid>
                            <StackPanel IsVisible="{Binding HasSelectedVaultSource}" Spacing="18">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                    <Border Width="54" Height="54" CornerRadius="27" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                        <ic:FluentIcon Icon="Database" FontSize="24" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedVaultSource.DisplayName}" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding SelectedVaultSource.Kind}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                                <Grid ColumnDefinitions="90,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="12" MinWidth="0">
                                    <TextBlock Classes="workspaceDetailLabel" Text="{Binding L.LocalPath}" />
                                    <TextBlock Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedVaultSource.LocalPath}" MaxLines="2" />
                                    <TextBlock Grid.Row="1" Classes="workspaceDetailLabel" Text="{Binding L.MdbxRemotePath}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedVaultSource.RemoteUrl}" MaxLines="2" />
                                    <TextBlock Grid.Row="2" Classes="workspaceDetailLabel" Text="{Binding L.SyncOverview}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedVaultSource.SyncStatus}" MaxLines="2" />
                                </Grid>
                                <WrapPanel Orientation="Horizontal">
                                    <Button Classes="workspacePrimaryCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Mdbx" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ic:FluentIcon Icon="Database" FontSize="18" />
                                            <TextBlock Text="{Binding L.MdbxVaults}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Sync" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ic:FluentIcon Icon="ArrowSync" FontSize="16" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding L.SyncAndBackup}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                            <StackPanel IsVisible="{Binding !HasSelectedVaultSource}" Spacing="10" Width="260" Margin="24" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <ic:FluentIcon Icon="Database" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding VaultSourceCountText}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="databaseWorkbench" Padding="20" IsVisible="{Binding IsDatabaseOverviewSelected}">
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                        <Border Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:FluentIcon Icon="Database" FontSize="20" />
                                    <TextBlock Text="{Binding L.LocalDatabase}" FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock Text="{Binding LocalDatabaseSummaryText}" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="2" />
                                <TextBlock Text="{Binding L.LocalDatabaseDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" MaxLines="3" />
                                <WrapPanel Orientation="Horizontal">
                                    <Button Classes="workspaceCommand" Command="{Binding LoadCommand}" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                                            <TextBlock Text="{Binding L.Refresh}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Passwords" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ic:FluentIcon Icon="Key" FontSize="18" />
                                            <TextBlock Text="{Binding L.Passwords}" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:FluentIcon Icon="Folder" FontSize="20" />
                                    <TextBlock Text="{Binding L.ExternalDatabases}" FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock Text="{Binding L.ExternalDatabasesDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" MaxLines="4" />
                                <WrapPanel Orientation="Horizontal">
                                    <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Sync" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ic:FluentIcon Icon="Key" FontSize="16" VerticalAlignment="Center" />
                                            <TextBlock Text="KDBX" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Mdbx" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ic:FluentIcon Icon="Database" FontSize="16" VerticalAlignment="Center" />
                                            <TextBlock Text="MDBX" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Sync" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ic:FluentIcon Icon="Cloud" FontSize="16" VerticalAlignment="Center" />
                                            <TextBlock Text="Bitwarden" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        </Grid>
                    </Border>

                    <Border Classes="databaseWorkbench" Padding="20" IsVisible="{Binding IsDatabaseCloudSelected}">
                        <StackPanel Spacing="14">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Width="44" Height="44" CornerRadius="22" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                    <ic:FluentIcon Icon="Cloud" FontSize="22" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding L.CloudAndLocalVaults}" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding L.CloudAndLocalVaultsDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                                <Border Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{Binding L.MdbxDatabaseCount}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding MdbxDatabaseCountText}" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <Button Classes="workspacePrimaryCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Mdbx" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Database" FontSize="18" />
                                                <TextBlock Text="{Binding L.MdbxVaults}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                                        <TextBlock Text="{Binding L.MdbxLocalCache}" FontWeight="SemiBold" />
                                        <ToggleSwitch Grid.Column="1" Grid.RowSpan="2" IsChecked="{Binding MdbxLocalCacheEnabled}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Text="{Binding L.MdbxLocalCacheDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1" Grid.ColumnSpan="2" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                                        <TextBlock Text="{Binding L.EnableOneDrive}" FontWeight="SemiBold" />
                                        <ToggleSwitch Grid.Column="1" Grid.RowSpan="2" IsChecked="{Binding OneDriveEnabled}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Text="{Binding L.EnableOneDriveDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="databaseWorkbench" Padding="20" IsVisible="{Binding IsDatabaseCapabilitiesSelected}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="{Binding L.FeatureParityMap}" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding L.FeatureParityMapDescription}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <ItemsControl ItemsSource="{Binding Capabilities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LocalizedPlatformCapability">
                                        <Border Margin="0,0,0,10" Padding="14" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                                <StackPanel Spacing="4" MinWidth="0">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding UnsupportedReason}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" IsVisible="{Binding HasUnsupportedReason}" />
                                                </StackPanel>
                                                <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEnabled, Mode=TwoWay}" IsEnabled="{Binding CanToggle}" ToolTip.Tip="{Binding ToggleStatus}" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <fa:FASettingsExpander Width="374" Margin="0,0,12,12" Header="{Binding L.ImportData}" Description="{Binding L.ImportDataDescription}" IsExpanded="False">
                            <fa:FASettingsExpander.IconSource>
                                <fa:FASymbolIconSource Symbol="Folder" />
                            </fa:FASettingsExpander.IconSource>
                            <StackPanel Spacing="8">
                                <TextBox Text="{Binding ImportJsonText}" PlaceholderText="{Binding L.ImportJsonWatermark}" AcceptsReturn="True" MinHeight="100" TextWrapping="Wrap" />
                                <Button Command="{Binding ImportDataCommand}" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ic:FluentIcon Icon="ArrowUpload" FontSize="20" />
                                        <TextBlock Text="{Binding L.Import}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </fa:FASettingsExpander>

                        <fa:FASettingsExpander Width="374" Margin="0,0,0,12" Header="{Binding L.ExportData}" Description="{Binding L.ExportDataDescription}" IsExpanded="False">
                            <fa:FASettingsExpander.IconSource>
                                <fa:FASymbolIconSource Symbol="ProtectedDocument" />
                            </fa:FASettingsExpander.IconSource>
                            <StackPanel Spacing="8">
                                <Button Command="{Binding ExportDataCommand}" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ic:FluentIcon Icon="ArrowDownload" FontSize="20" />
                                        <TextBlock Text="{Binding L.Export}" />
                                    </StackPanel>
                                </Button>
                                <TextBox Text="{Binding ExportPreview}" AcceptsReturn="True" MinHeight="100" TextWrapping="Wrap" />
                            </StackPanel>
                        </fa:FASettingsExpander>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
</Grid>
</UserControl>
