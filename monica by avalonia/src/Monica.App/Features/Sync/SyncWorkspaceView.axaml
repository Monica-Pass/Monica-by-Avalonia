<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ic="using:FluentIcons.Avalonia" xmlns:local="using:Monica.App" xmlns:sync="using:Monica.App.Features.Sync" xmlns:vm="using:Monica.App.ViewModels" x:Class="Monica.App.Features.Sync.SyncWorkspaceView" x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <StyleInclude Source="/Features/Sync/SyncStyles.axaml" />
    </UserControl.Styles>
    <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsSync}}" RowDefinitions="Auto,*" MaxWidth="1080" HorizontalAlignment="Stretch" ClipToBounds="True">
        <Border Classes="workspacePageHeader">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                <TextBlock Classes="workspacePageTitle" Text="{Binding L.SyncAndBackup}" />
                <TextBlock Grid.Row="1" Classes="workspacePageSubtitle" Text="{Binding L.SyncSubtitle}" MaxWidth="620" HorizontalAlignment="Left" />
                <WrapPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal">
                    <Button Classes="workspaceCommand" Command="{Binding TestWebDavConnectionCommand}" IsEnabled="{Binding !IsWebDavBusy}" Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:FluentIcon Icon="ArrowSync" FontSize="18" />
                            <TextBlock Text="{Binding L.TestConnection}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="workspacePrimaryCommand" Command="{Binding CreateWebDavBackupCommand}" IsEnabled="{Binding !IsWebDavBusy}" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:FluentIcon Icon="ArrowUpload" FontSize="18" />
                            <TextBlock Text="{Binding L.BackupNow}" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>
        <Grid x:Name="SyncWorkspaceLayoutGrid" Grid.Row="1" ColumnDefinitions="320,*" RowDefinitions="*" ColumnSpacing="16" RowSpacing="12" MinWidth="0">
            <Border x:Name="SyncSidebarRegion" Classes="workspaceSidebar" Padding="14" ClipToBounds="True">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="14">
                        <StackPanel x:Name="SyncSidebarOverview" Spacing="12">
                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.SyncOverview}" />
                            <ItemsControl ItemsSource="{Binding SyncHealthItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SyncHealthDisplayItem">
                                        <Border Width="130" MinHeight="96" Margin="0,0,8,8" Padding="10" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Label}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Value}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="2" />
                                                <TextBlock Text="{Binding Detail}" FontSize="12" TextWrapping="Wrap" MaxLines="2" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{Binding SyncRecoverySummaryText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.SyncAndBackup}" />
                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncConfigurationSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Configuration">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ic:FluentIcon Icon="ArrowSync" FontSize="17" />
                                    <TextBlock Text="{Binding L.SyncConfiguration}" />
                                </StackPanel>
                            </Button>
                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncBackupSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Backup">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ic:FluentIcon Icon="Save" FontSize="17" />
                                    <TextBlock Text="{Binding L.BackupHistory}" />
                                </StackPanel>
                            </Button>
                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncSourcesSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Sources">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ic:FluentIcon Icon="Database" FontSize="17" />
                                    <TextBlock Text="{Binding L.CloudAndLocalVaults}" />
                                </StackPanel>
                            </Button>
                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncImportSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Import">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ic:FluentIcon Icon="ArrowUpload" FontSize="17" />
                                    <TextBlock Text="{Binding L.ImportData}" />
                                </StackPanel>
                            </Button>
                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncExportSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Export">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ic:FluentIcon Icon="ArrowDownload" FontSize="17" />
                                    <TextBlock Text="{Binding L.ExportData}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <ScrollViewer x:Name="SyncContentRegion" Grid.Column="1" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                <StackPanel Spacing="14" MaxWidth="720" HorizontalAlignment="Stretch">
                    <sync:SyncConfigurationView />
                    <sync:SyncBackupView />
                    <sync:SyncSourcesView />
                    <sync:SyncImportView />
                    <sync:SyncExportView />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
