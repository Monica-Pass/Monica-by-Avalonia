<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ic="using:FluentIcons.Avalonia" xmlns:local="using:Monica.App" xmlns:sync="using:Monica.App.Features.Sync" xmlns:vm="using:Monica.App.ViewModels" x:Class="Monica.App.Features.Sync.SyncWorkspaceView" x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <StyleInclude Source="/Features/Sync/SyncStyles.axaml" />
    </UserControl.Styles>
    <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsSync}}" RowDefinitions="Auto,*" HorizontalAlignment="Stretch" ClipToBounds="True">
        <Border x:Name="SyncOperationsCommandSurface" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,14" Margin="0,0,0,8">
            <Grid x:Name="SyncHeaderGrid" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                <TextBlock Classes="workspacePageTitle" Text="{Binding L.SyncAndBackup}" />
                <TextBlock Grid.Row="1" Classes="workspacePageSubtitle" Text="{Binding L.SyncSubtitle}" MaxWidth="620" HorizontalAlignment="Left" />
                <sync:SyncCommandBarView x:Name="SyncCommandBar" Grid.Column="1" Grid.RowSpan="2" />
                <Border x:Name="WebDavOperationProgressRegion"
                        Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Padding="12,9"
                        CornerRadius="7"
                        BorderBrush="{DynamicResource AccentFillColorSecondaryBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource LayerFillColorSubtleBrush}"
                        IsVisible="{Binding IsWebDavBusy}"
                        AutomationProperties.Name="{Binding WebDavOperationStageText}">
                    <Grid ColumnDefinitions="160,*" ColumnSpacing="12">
                        <ProgressBar x:Name="WebDavOperationProgressBar"
                                     IsIndeterminate="True"
                                     VerticalAlignment="Center"
                                     AutomationProperties.Name="{Binding WebDavOperationStageText}" />
                        <TextBlock x:Name="WebDavOperationStageText"
                                   Grid.Column="1"
                                   Text="{Binding WebDavOperationStageText}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   AutomationProperties.LiveSetting="Polite" />
                    </Grid>
                </Border>
                <ScrollViewer x:Name="SyncHealthStatusRegion" Grid.Row="3" Grid.ColumnSpan="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding SyncHealthItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SyncHealthDisplayItem">
                                    <Border Width="180" MinHeight="64" Margin="0,0,8,0" Padding="12,8" CornerRadius="4" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Background="Transparent">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Label}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Value}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Detail}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding SyncRecoverySummaryText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,6,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
        <Grid x:Name="SyncWorkspaceLayoutGrid" Grid.Row="1" ColumnDefinitions="260,*" RowDefinitions="*" MinWidth="0">
            <Border x:Name="SyncSidebarRegion" Classes="workspaceSidebar" Padding="14" ClipToBounds="True" CornerRadius="0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Background="Transparent">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.SyncAndBackup}" />
                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncConfigurationSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Configuration">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ic:FluentIcon Icon="ArrowSync" FontSize="17" />
                                    <TextBlock Text="{Binding L.SyncConfiguration}" />
                                </StackPanel>
                            </Button>
                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncBackupSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Backup">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ic:FluentIcon Icon="Save" FontSize="17" />
                                    <TextBlock Text="{Binding L.BackupHistory}" />
                                </StackPanel>
                            </Button>
                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncSourcesSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Sources">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ic:FluentIcon Icon="Database" FontSize="17" />
                                    <TextBlock Text="{Binding L.CloudAndLocalVaults}" />
                                </StackPanel>
                            </Button>
                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncImportSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Import">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ic:FluentIcon Icon="ArrowUpload" FontSize="17" />
                                    <TextBlock Text="{Binding L.ImportData}" />
                                </StackPanel>
                            </Button>
                            <Button Classes="workspaceNavItem" Classes.accent="{Binding IsSyncExportSelected}" Command="{Binding SelectSyncPageCommand}" CommandParameter="Export">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ic:FluentIcon Icon="ArrowDownload" FontSize="17" />
                                    <TextBlock Text="{Binding L.ExportData}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <ScrollViewer x:Name="SyncContentRegion" Grid.Column="1" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                <StackPanel Spacing="14" MaxWidth="760" HorizontalAlignment="Stretch" Margin="28,18,20,20">
                    <sync:SyncPageHostView x:Name="SyncPageHost" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
