<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:local="using:Monica.App"
             xmlns:views="using:Monica.App.Features.Timeline"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.Timeline.TimelineWorkspaceView"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <StyleInclude Source="/Features/Timeline/TimelineStyles.axaml" />
    </UserControl.Styles>
    <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsTimeline}}"
          RowDefinitions="Auto,*"
          HorizontalAlignment="Stretch"
          ClipToBounds="True">
        <Border x:Name="TimelineQueryCommandSurface" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,8">
            <Grid x:Name="TimelineHeaderGrid" ColumnDefinitions="*,320,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" MinHeight="56">
                <StackPanel MinWidth="0" VerticalAlignment="Center">
                    <TextBlock Classes="workspacePageTitle" Text="{Binding L.Timeline}" />
                    <TextBlock Text="{Binding TimelineCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Grid x:Name="TimelineSearchRegion" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="6" VerticalAlignment="Center">
                    <TextBox x:Name="TimelineSearchBox" PlaceholderText="{Binding L.Search}" Text="{Binding TimelineSearchText}" AutomationProperties.Name="{Binding L.Search}" />
                    <Button x:Name="TimelineSearchClearButton" Grid.Column="1" Classes="workspaceCommand" Command="{Binding ClearTimelineSearchCommand}" IsVisible="{Binding HasTimelineSearchText}" ToolTip.Tip="{Binding L[Clear]}" AutomationProperties.Name="{Binding L[Clear]}" Width="40" Height="40" Padding="0">
                        <ic:FluentIcon Icon="Dismiss" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </Grid>
                <views:TimelineCommandBarView x:Name="TimelineCommandBar" Grid.Column="2" />
            </Grid>
        </Border>

        <Grid x:Name="TimelineMasterDetailGrid" Grid.Row="1" ColumnDefinitions="440,*" MinWidth="0">
            <Border x:Name="TimelineListRegion" Classes="timelineFilterRail" ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Margin="14,12,14,8" Spacing="3">
                        <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.Timeline}" />
                        <TextBlock Text="{Binding TimelineCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" AutomationProperties.LiveSetting="Polite" />
                    </StackPanel>
                    <views:TimelineEntryListView x:Name="TimelineEntryListView" Grid.Row="1" />
                </Grid>
            </Border>
            <Border x:Name="TimelineDetailRegion" Grid.Column="1" Classes="timelineInspector" Padding="28,22" MinWidth="0" Focusable="True">
                <views:TimelineInspectorView x:Name="TimelineInspectorView" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
