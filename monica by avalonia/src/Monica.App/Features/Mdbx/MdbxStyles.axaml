<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Style Selector="ListBox.mdbxWorkingCopyList ListBoxItem">
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="MinHeight" Value="88" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Stretch" />
</Style>
<Style Selector="ListBox.mdbxWorkingCopyList ListBoxItem:selected">
    <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
</Style>
<Style Selector="Button.mdbxWorkingCopyButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Stretch" />
</Style>
<Style Selector="Button.mdbxWorkingCopyButton:pointerover">
    <Setter Property="Background" Value="Transparent" />
</Style>
<Style Selector="Border.mdbxWorkingCopyRow">
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="MinHeight" Value="88" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Background" Value="Transparent" />
</Style>
<Style Selector="Border.mdbxSourceRail">
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
</Style>
<Style Selector="Border.mdbxWorkbench">
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
</Style>
<Style Selector="Border.mdbxDiagnosticTile">
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
</Style>
<Style Selector="Button.mdbxPivotButton">
    <Setter Property="MinHeight" Value="38" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
</Style>
<Style Selector="Button.mdbxPivotButton.accent">
    <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
    <Setter Property="BorderThickness" Value="0" />
</Style>
</Styles>
