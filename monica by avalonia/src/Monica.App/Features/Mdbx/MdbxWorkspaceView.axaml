<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ic="using:FluentIcons.Avalonia" xmlns:local="using:Monica.App" xmlns:mdbx="using:Monica.App.Features.Mdbx" xmlns:vm="using:Monica.App.ViewModels" x:Class="Monica.App.Features.Mdbx.MdbxWorkspaceView" x:Name="MdbxWorkspaceRoot" x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <StyleInclude Source="/Features/Mdbx/MdbxStyles.axaml" />
    </UserControl.Styles>
    <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsMdbx}}" RowDefinitions="Auto,*" ClipToBounds="True">
        <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
            <Grid x:Name="MdbxHeaderGrid" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                <TextBlock Classes="workspacePageTitle" Text="{Binding L.MdbxVaults}" />
                <TextBlock Grid.Row="1" Classes="workspacePageSubtitle" Text="{Binding MdbxWorkingCopySummaryText}" MaxWidth="720" HorizontalAlignment="Left" />
                <mdbx:MdbxCommandBarView x:Name="MdbxCommandBar" Grid.Column="1" Grid.RowSpan="2" VerticalAlignment="Center" />
            </Grid>
        </Border>
        <Grid x:Name="MdbxWorkspaceLayoutGrid" Grid.Row="1" ColumnDefinitions="360,*" RowDefinitions="*" ColumnSpacing="14" RowSpacing="12" MinWidth="0">
            <Border x:Name="MdbxListRegion" Classes="mdbxSourceRail" ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <Grid Margin="14,12,14,8" ColumnDefinitions="*" ColumnSpacing="8">
                        <StackPanel Spacing="3">
                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.MdbxWorkingCopiesSection}" />
                            <TextBlock Text="{Binding MdbxWorkingCopySummaryText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" MaxLines="2" />
                        </StackPanel>
                    </Grid>
                    <mdbx:MdbxDatabaseListView x:Name="MdbxDatabaseListView" Grid.Row="1" />
                </Grid>
            </Border>
            <ScrollViewer x:Name="MdbxContentRegion" Grid.Column="1" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                        <Button Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxHealthSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Health">
                            <TextBlock Text="{Binding L.MdbxHealthSection}" TextTrimming="CharacterEllipsis" />
                        </Button>
                        <Button Grid.Column="1" Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxDetailsSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Details">
                            <TextBlock Text="{Binding L.Details}" TextTrimming="CharacterEllipsis" />
                        </Button>
                        <Button Grid.Column="2" Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxSourcesSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Sources">
                            <TextBlock Text="{Binding L.MdbxSourcesSection}" TextTrimming="CharacterEllipsis" />
                        </Button>
                        <Button Grid.Column="3" Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxRuntimeSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Runtime">
                            <TextBlock Text="{Binding L.MdbxRuntime}" TextTrimming="CharacterEllipsis" />
                        </Button>
                    </Grid>
                    <mdbx:MdbxWorkbenchView />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
