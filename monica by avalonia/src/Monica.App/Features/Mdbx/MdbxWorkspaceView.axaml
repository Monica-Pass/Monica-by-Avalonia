<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:local="using:Monica.App"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.Mdbx.MdbxWorkspaceView"
             x:Name="MdbxWorkspaceRoot"
             x:DataType="vm:MainWindowViewModel">
<Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsMdbx}}"
      RowDefinitions="Auto,*"
      HorizontalAlignment="Stretch"
      ClipToBounds="True">
        <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                <TextBlock Classes="workspacePageTitle" Text="{Binding L.MdbxVaults}" />
                <TextBlock Grid.Row="1" Classes="workspacePageSubtitle" Text="{Binding MdbxWorkingCopySummaryText}" MaxWidth="720" HorizontalAlignment="Left" />
                <WrapPanel Grid.Column="1" Grid.RowSpan="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Classes="workspacePrimaryCommand" Command="{Binding CreateMdbxVaultCommand}" Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:FluentIcon Icon="Database" FontSize="18" />
                            <TextBlock Text="{Binding L.CreateLocalMdbxVault}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="workspaceCommand" Command="{Binding RefreshMdbxVaultsCommand}" Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                            <TextBlock Text="{Binding L.Refresh}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="workspaceCommand" ToolTip.Tip="{Binding L.MoreOptions}" AutomationProperties.Name="{Binding L.MoreOptions}" Width="36" Height="36" Padding="0" Margin="0,0,0,8">
                        <ic:FluentIcon Icon="MoreHorizontal" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="{Binding L.Configure}" Command="{Binding ConfigureMdbxRemoteSourcesCommand}">
                                    <MenuItem.Icon>
                                        <ic:FluentIcon Icon="Cloud" FontSize="16" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="360,*" ColumnSpacing="14" MinWidth="0">
            <Border Classes="mdbxSourceRail" ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <Grid Margin="14,12,14,8" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <StackPanel Spacing="3">
                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.MdbxWorkingCopiesSection}" />
                            <TextBlock Text="{Binding MdbxWorkingCopySummaryText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" MaxLines="2" />
                        </StackPanel>
                        <Button Grid.Column="1" Classes="workspaceCommand" Command="{Binding CreateMdbxVaultCommand}" ToolTip.Tip="{Binding L.CreateLocalMdbxVault}" AutomationProperties.Name="{Binding L.CreateLocalMdbxVault}" Width="34" Height="34" Padding="0">
                            <ic:FluentIcon Icon="Add" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                        <Button Grid.Column="2" Classes="workspaceCommand" Command="{Binding RefreshMdbxVaultsCommand}" ToolTip.Tip="{Binding L.Refresh}" AutomationProperties.Name="{Binding L.Refresh}" Width="34" Height="34" Padding="0">
                            <ic:FluentIcon Icon="ArrowClockwise" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1">
                        <StackPanel IsVisible="{Binding !HasMdbxDatabases}" HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="10" Margin="24" Width="240">
                            <ic:FluentIcon Icon="Database" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding L.NoMdbxVaults}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding L.MdbxEmptyHint}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                            <Button Classes="workspacePrimaryCommand" Command="{Binding CreateMdbxVaultCommand}" ToolTip.Tip="{Binding L.CreateLocalMdbxVault}" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:FluentIcon Icon="Database" FontSize="16" />
                                    <TextBlock Text="{Binding L.CreateLocalMdbxVault}" />
                                </StackPanel>
                            </Button>
                            <Button Classes="workspaceCommand" Command="{Binding ConfigureMdbxRemoteSourcesCommand}" ToolTip.Tip="{Binding L.Configure}" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:FluentIcon Icon="Cloud" FontSize="16" />
                                    <TextBlock Text="{Binding L.Configure}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <ListBox Classes="mdbxWorkingCopyList" ItemsSource="{Binding MdbxDatabaseItems}" SelectedItem="{Binding SelectedMdbxDatabaseItem}" IsVisible="{Binding HasMdbxDatabases}" SelectionMode="Single" Margin="8,0,8,8">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:MdbxDatabaseDisplayItem">
                                    <Border Classes="mdbxWorkingCopyRow">
                                        <Button Classes="mdbxWorkingCopyButton"
                                                Command="{Binding #MdbxWorkspaceRoot.DataContext.ShowMdbxDatabaseDetailsCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{Binding Name}">
                                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="3" ColumnSpacing="10">
                                                <StackPanel Orientation="Horizontal" Spacing="7" MinWidth="0">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <Border Classes="workspaceStatusChip" IsVisible="{Binding IsDefault}">
                                                        <TextBlock Text="{Binding #MdbxWorkspaceRoot.DataContext.L.Default}" FontSize="12" />
                                                    </Border>
                                                </StackPanel>
                                                <Border Grid.Column="1" Grid.RowSpan="2" Classes="workspaceStatusChip" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Source}" FontSize="12" />
                                                </Border>
                                                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding LocalPath}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding SyncStatus}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                            </Grid>
                                        </Button>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <ScrollViewer x:Name="MdbxWorkspaceScrollViewer" Grid.Column="1" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                <StackPanel Spacing="14" HorizontalAlignment="Stretch">
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                        <Button Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxHealthSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Health">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="Shield" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding L.MdbxHealthSection}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxDetailsSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Details">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="Database" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding L.Details}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxSourcesSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Sources">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="Cloud" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding L.MdbxSourcesSection}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxRuntimeSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Runtime">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="Library" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding L.MdbxRuntime}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Classes="mdbxWorkbench" Padding="20" MinWidth="0" IsVisible="{Binding IsMdbxDetailsSelected}">
                        <Grid>
                            <StackPanel IsVisible="{Binding HasSelectedMdbxDatabaseItem}" Spacing="18">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                    <Border Width="54" Height="54" CornerRadius="27" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                        <ic:FluentIcon Icon="Database" FontSize="24" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding SelectedMdbxDatabaseItem.Name}" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <Border Classes="workspaceStatusChip" IsVisible="{Binding SelectedMdbxDatabaseItem.IsDefault}">
                                                <TextBlock Text="{Binding L.Default}" FontSize="12" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding SelectedMdbxDatabaseItem.Description}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                                <WrapPanel Orientation="Horizontal">
                                    <Border Classes="workspaceStatusChip" Margin="0,0,8,8">
                                        <TextBlock Text="{Binding SelectedMdbxDatabaseItem.Source}" FontSize="12" FontWeight="SemiBold" />
                                    </Border>
                                    <Border Classes="workspaceStatusChip" Margin="0,0,8,8">
                                        <TextBlock Text="{Binding SelectedMdbxDatabaseItem.WorkingCopyStatus}" FontSize="12" />
                                    </Border>
                                    <Border Classes="workspaceStatusChip" Margin="0,0,8,8">
                                        <TextBlock Text="{Binding SelectedMdbxDatabaseItem.SyncStatus}" FontSize="12" />
                                    </Border>
                                </WrapPanel>
                                <Grid ColumnDefinitions="90,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="12" MinWidth="0">
                                    <TextBlock Classes="workspaceDetailLabel" Text="{Binding L.LocalPath}" />
                                    <TextBlock Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedMdbxDatabaseItem.LocalPath}" MaxLines="2" />
                                    <TextBlock Grid.Row="1" Classes="workspaceDetailLabel" Text="{Binding L.MdbxRemotePath}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedMdbxDatabaseItem.RemotePath}" MaxLines="2" />
                                    <TextBlock Grid.Row="2" Classes="workspaceDetailLabel" Text="{Binding L.MdbxLastSynced}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedMdbxDatabaseItem.LastSyncedText}" MaxLines="2" />
                                    <TextBlock Grid.Row="3" Classes="workspaceDetailLabel" Text="{Binding L.MdbxRemotePath}" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedMdbxDatabaseItem.RemoteStatus}" MaxLines="2" />
                                    <TextBlock Grid.Row="4" Classes="workspaceDetailLabel" Text="{Binding L.MdbxDiagnostics}" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedMdbxDatabaseItem.LastSyncErrorText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" MaxLines="2" />
                                </Grid>
                                <WrapPanel Orientation="Horizontal" MaxWidth="500">
                                    <Button Classes="workspacePrimaryCommand" Command="{Binding OpenMdbxDatabaseCommand}" CommandParameter="{Binding SelectedMdbxDatabaseItem}" Margin="0,0,8,8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ic:FluentIcon Icon="ArrowDownload" FontSize="18" />
                                            <TextBlock Text="{Binding L.Open}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Classes="workspaceCommand" Command="{Binding SetDefaultMdbxDatabaseCommand}" CommandParameter="{Binding SelectedMdbxDatabaseItem}" IsEnabled="{Binding !SelectedMdbxDatabaseItem.IsDefault}" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding L.SetDefault}" />
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                            <StackPanel IsVisible="{Binding !HasSelectedMdbxDatabaseItem}" Spacing="10" Width="260" Margin="24" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <ic:FluentIcon Icon="Database" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding L.NoMdbxVaults}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding L.MdbxEmptyHint}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <Button Classes="workspacePrimaryCommand" Command="{Binding CreateMdbxVaultCommand}" ToolTip.Tip="{Binding L.CreateLocalMdbxVault}" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ic:FluentIcon Icon="Database" FontSize="16" />
                                        <TextBlock Text="{Binding L.CreateLocalMdbxVault}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="mdbxWorkbench" Padding="20" IsVisible="{Binding IsMdbxHealthSelected}">
                        <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border Width="44" Height="44" CornerRadius="22" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                <ic:FluentIcon Icon="Shield" FontSize="22" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding L.MdbxHealthSection}" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding MdbxSyncDiagnosticsSummaryText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding MdbxHealthItems}" HorizontalAlignment="Stretch">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SyncHealthDisplayItem">
                                    <Border Classes="mdbxDiagnosticTile" Width="260" MinHeight="112" Margin="0,0,10,10" Padding="14">
                                        <StackPanel Spacing="4" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Label}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Value}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="2" />
                                            <TextBlock Text="{Binding Detail}" FontSize="12" TextWrapping="Wrap" MaxLines="3" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Classes="mdbxWorkbench" Padding="20" IsVisible="{Binding IsMdbxSourcesSelected}">
                        <StackPanel Spacing="14">
                        <TextBlock Text="{Binding L.MdbxSourcesSection}" FontSize="20" FontWeight="SemiBold" />
                        <StackPanel Spacing="10">
                            <Border MinHeight="160" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}" HorizontalAlignment="Stretch">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ic:FluentIcon Icon="Database" FontSize="20" />
                                        <TextBlock Text="{Binding L.MdbxLocalSource}" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding MdbxLocalCountText}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding MdbxLocalSourceStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" MaxLines="3" MaxWidth="340" HorizontalAlignment="Left" />
                                    <Button Classes="workspacePrimaryCommand" Command="{Binding CreateMdbxVaultCommand}" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ic:FluentIcon Icon="Database" FontSize="18" />
                                            <TextBlock Text="{Binding L.CreateLocalMdbxVault}" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <Border MinHeight="160" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}" HorizontalAlignment="Stretch">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ic:FluentIcon Icon="Cloud" FontSize="20" />
                                        <TextBlock Text="{Binding L.MdbxWebDavSource}" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding MdbxWebDavCountText}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding MdbxWebDavSourceStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" MaxLines="3" MaxWidth="340" HorizontalAlignment="Left" />
                                    <WrapPanel Orientation="Horizontal">
                                        <Button Classes="workspaceCommand" Command="{Binding CreateWebDavMdbxVaultCommand}" Margin="0,0,8,8">
                                            <ic:FluentIcon Icon="ArrowUpload" FontSize="18" />
                                        </Button>
                                        <Button Classes="workspaceCommand" Command="{Binding ConfigureMdbxRemoteSourcesCommand}" Margin="0,0,0,8">
                                            <ic:FluentIcon Icon="Database" FontSize="18" />
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border MinHeight="160" Padding="16" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}" HorizontalAlignment="Stretch">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <ic:FluentIcon Icon="Cloud" FontSize="20" />
                                        <TextBlock Text="{Binding L.MdbxOneDriveSource}" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding MdbxOneDriveCountText}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding MdbxOneDriveSourceStatusText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" MaxLines="3" MaxWidth="340" HorizontalAlignment="Left" />
                                    <WrapPanel Orientation="Horizontal">
                                        <Button Classes="workspaceCommand" Command="{Binding CreateOneDriveMdbxVaultCommand}" Margin="0,0,8,8">
                                            <ic:FluentIcon Icon="ArrowUpload" FontSize="18" />
                                        </Button>
                                        <Button Classes="workspaceCommand" Command="{Binding ConfigureMdbxRemoteSourcesCommand}" Margin="0,0,0,8">
                                            <ic:FluentIcon Icon="Database" FontSize="18" />
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Classes="mdbxWorkbench" Padding="20" IsVisible="{Binding IsMdbxRuntimeSelected}">
                        <StackPanel Spacing="16">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border Width="44" Height="44" CornerRadius="22" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                                    <ic:FluentIcon Icon="Library" FontSize="22" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding L.MdbxRuntime}" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding MdbxRuntimeSummaryText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                            <Border Classes="mdbxDiagnosticTile" Padding="16">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Spacing="4" MinWidth="0">
                                        <TextBlock Text="{Binding L.MdbxLocalCache}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding MdbxCachePolicyText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding MdbxLocalCacheEnabled}" OnContent="{Binding L.FeatureEnabled}" OffContent="{Binding L.FeatureDisabled}" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Border Classes="mdbxDiagnosticTile" Padding="16">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding L.MdbxSecurity}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding MdbxSecuritySummaryText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Classes="mdbxDiagnosticTile" Padding="16">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding L.MdbxDiagnostics}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding MdbxSyncDiagnosticsSummaryText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <Border Classes="mdbxDiagnosticTile" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding L.MdbxAndroidParity}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding L.MdbxAndroidParityLocal}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding L.MdbxAndroidParityRemote}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
</Grid>

</UserControl>
