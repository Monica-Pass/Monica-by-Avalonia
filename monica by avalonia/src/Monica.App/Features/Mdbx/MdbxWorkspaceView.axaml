<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ic="using:FluentIcons.Avalonia" xmlns:local="using:Monica.App" xmlns:mdbx="using:Monica.App.Features.Mdbx" xmlns:vm="using:Monica.App.ViewModels" x:Class="Monica.App.Features.Mdbx.MdbxWorkspaceView" x:Name="MdbxWorkspaceRoot" x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <StyleInclude Source="/Features/Mdbx/MdbxStyles.axaml" />
    </UserControl.Styles>
    <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsMdbx}}" RowDefinitions="Auto,*" ClipToBounds="True">
        <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                <TextBlock Classes="workspacePageTitle" Text="{Binding L.MdbxVaults}" />
                <TextBlock Grid.Row="1" Classes="workspacePageSubtitle" Text="{Binding MdbxWorkingCopySummaryText}" MaxWidth="720" HorizontalAlignment="Left" />
                <WrapPanel Grid.Column="1" Grid.RowSpan="2" VerticalAlignment="Center">
                    <Button Classes="workspacePrimaryCommand" Command="{Binding CreateMdbxVaultCommand}" IsEnabled="{Binding !IsMdbxBusy}" Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:FluentIcon Icon="Database" FontSize="18" />
                            <TextBlock Text="{Binding L.CreateLocalMdbxVault}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="workspaceCommand" Command="{Binding RefreshMdbxVaultsCommand}" IsEnabled="{Binding !IsMdbxBusy}" Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:FluentIcon Icon="ArrowClockwise" FontSize="18" />
                            <TextBlock Text="{Binding L.Refresh}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="workspaceCommand" ToolTip.Tip="{Binding L.MoreOptions}" AutomationProperties.Name="{Binding L.MoreOptions}" Width="36" Height="36" Padding="0" Margin="0,0,0,8">
                        <ic:FluentIcon Icon="MoreHorizontal" FontSize="17" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="{Binding L.Configure}" Command="{Binding ConfigureMdbxRemoteSourcesCommand}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>
        <Grid x:Name="MdbxWorkspaceLayoutGrid" Grid.Row="1" ColumnDefinitions="360,*" RowDefinitions="*" ColumnSpacing="14" RowSpacing="12" MinWidth="0">
            <Border x:Name="MdbxListRegion" Classes="mdbxSourceRail" ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <Grid Margin="14,12,14,8" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <StackPanel Spacing="3">
                            <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.MdbxWorkingCopiesSection}" />
                            <TextBlock Text="{Binding MdbxWorkingCopySummaryText}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" MaxLines="2" />
                        </StackPanel>
                        <Button Grid.Column="1" Classes="workspaceCommand" Command="{Binding CreateMdbxVaultCommand}" IsEnabled="{Binding !IsMdbxBusy}" ToolTip.Tip="{Binding L.CreateLocalMdbxVault}" AutomationProperties.Name="{Binding L.CreateLocalMdbxVault}" Width="34" Height="34" Padding="0">
                            <ic:FluentIcon Icon="Add" FontSize="16" />
                        </Button>
                        <Button Grid.Column="2" Classes="workspaceCommand" Command="{Binding RefreshMdbxVaultsCommand}" IsEnabled="{Binding !IsMdbxBusy}" ToolTip.Tip="{Binding L.Refresh}" AutomationProperties.Name="{Binding L.Refresh}" Width="34" Height="34" Padding="0">
                            <ic:FluentIcon Icon="ArrowClockwise" FontSize="16" />
                        </Button>
                    </Grid>
                    <Grid Grid.Row="1">
                        <StackPanel IsVisible="{Binding !HasMdbxDatabases}" Spacing="10" Margin="24" Width="240" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <ic:FluentIcon Icon="Database" FontSize="32" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="{Binding L.NoMdbxVaults}" TextAlignment="Center" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <Button Classes="workspacePrimaryCommand" Command="{Binding CreateMdbxVaultCommand}" IsEnabled="{Binding !IsMdbxBusy}" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding L.CreateLocalMdbxVault}" />
                            </Button>
                        </StackPanel>
                        <ListBox x:Name="MdbxDatabaseList" Classes="mdbxWorkingCopyList" ItemsSource="{Binding MdbxDatabaseItems}" SelectedItem="{Binding SelectedMdbxDatabaseItem}" IsVisible="{Binding HasMdbxDatabases}" SelectionMode="Single" Margin="8,0,8,8">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:MdbxDatabaseDisplayItem">
                                    <Border Classes="mdbxWorkingCopyRow">
                                        <Button Classes="mdbxWorkingCopyButton" Command="{Binding #MdbxWorkspaceRoot.DataContext.ShowMdbxDatabaseDetailsCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding Name}">
                                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="3" ColumnSpacing="10">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <Border Grid.Column="1" Grid.RowSpan="2" Classes="workspaceStatusChip">
                                                    <TextBlock Text="{Binding Source}" FontSize="12" />
                                                </Border>
                                                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding LocalPath}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding SyncStatus}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                            </Grid>
                                        </Button>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
            <ScrollViewer x:Name="MdbxContentRegion" Grid.Column="1" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                        <Button Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxHealthSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Health">
                            <TextBlock Text="{Binding L.MdbxHealthSection}" TextTrimming="CharacterEllipsis" />
                        </Button>
                        <Button Grid.Column="1" Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxDetailsSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Details">
                            <TextBlock Text="{Binding L.Details}" TextTrimming="CharacterEllipsis" />
                        </Button>
                        <Button Grid.Column="2" Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxSourcesSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Sources">
                            <TextBlock Text="{Binding L.MdbxSourcesSection}" TextTrimming="CharacterEllipsis" />
                        </Button>
                        <Button Grid.Column="3" Classes="mdbxPivotButton" Classes.accent="{Binding IsMdbxRuntimeSelected}" Command="{Binding SelectMdbxWorkspacePageCommand}" CommandParameter="Runtime">
                            <TextBlock Text="{Binding L.MdbxRuntime}" TextTrimming="CharacterEllipsis" />
                        </Button>
                    </Grid>
                    <mdbx:MdbxWorkbenchView />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
