<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.Notes.NoteTabStripView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">
    <Border x:Name="NoteDocumentCommandSurface"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Background="{DynamicResource LayerFillColorDefaultBrush}">
        <Grid Height="48">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding NoteTreeColumnWidth}" />
                <ColumnDefinition Width="{Binding NoteWorkspaceEditorColumnWidth}" />
                <ColumnDefinition Width="{Binding NoteInspectorColumnWidth}" />
            </Grid.ColumnDefinitions>

            <Border IsVisible="{Binding IsNoteTreePaneVisible}"
                    Padding="12,0"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                    <ic:FluentIcon Icon="Folder" FontSize="17" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding L.SecureNotes}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding NoteCountText}"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <Button x:Name="TreeAddNoteButton"
                            Grid.Column="3"
                            IsVisible="{Binding ShowAddNoteInTreeHeader}"
                            Command="{Binding AddNoteCommand}"
                            ToolTip.Tip="{Binding L.NewSecureNote}"
                            AutomationProperties.Name="{Binding L.NewSecureNote}"
                            Width="40"
                            Height="40"
                            Padding="0">
                        <ic:FluentIcon Icon="Add" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </Grid>
            </Border>

            <Grid x:Name="NoteTabRail"
                  Grid.Column="1"
                  IsVisible="{Binding IsNoteEditorWorkspaceVisible}"
                  ColumnDefinitions="Auto,*,Auto"
                  Background="{DynamicResource LayerFillColorSubtleBrush}">
                <Button x:Name="PreviousNoteTabButton"
                        Click="PreviousNoteTabButton_OnClick"
                        IsEnabled="False"
                        ToolTip.Tip="{Binding L[PreviousNoteTabs]}"
                        AutomationProperties.Name="{Binding L[PreviousNoteTabs]}"
                        Width="40"
                        Height="40"
                        Padding="0"
                        Margin="4"
                        VerticalAlignment="Top">
                    <ic:FluentIcon Icon="ChevronLeft" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>

                <ScrollViewer x:Name="NoteTabsScrollViewer"
                              Grid.Column="1"
                              Height="48"
                              MaxHeight="48"
                              MinWidth="0"
                              ClipToBounds="True"
                              SizeChanged="NoteTabsScrollViewer_OnSizeChanged"
                              ScrollChanged="NoteTabsScrollViewer_OnScrollChanged"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Hidden">
                    <ItemsControl ItemsSource="{Binding OpenNoteTabs}"
                                  Height="44"
                                  Margin="4,4,4,0"
                                  HorizontalAlignment="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:NoteEditorTab">
                                <Border Classes="noteTab"
                                        Classes.active="{Binding IsSelected}"
                                        Width="{Binding #Root.DataContext.NoteTabWidth}"
                                        MinWidth="76"
                                        MaxWidth="156"
                                        Height="34"
                                        Margin="0,4,4,0"
                                        BorderThickness="1,1,1,0"
                                        CornerRadius="4,4,0,0">
                                    <Grid RowDefinitions="3,*">
                                        <Border IsVisible="{Binding IsSelected}"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                CornerRadius="4,4,0,0" />
                                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" MinWidth="0">
                                            <Button Classes="noteTabButton"
                                                    Grid.ColumnSpan="2"
                                                    Command="{Binding #Root.DataContext.SelectNoteTabCommand}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="{Binding Title}">
                                                <Grid ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="5"
                                                      Margin="10,0,30,0"
                                                      MinWidth="0">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="13"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="*"
                                                               IsVisible="{Binding IsDirty}"
                                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Button>
                                            <Button Grid.Column="1"
                                                    Click="CloseNoteTabButton_OnClick"
                                                    IsVisible="{Binding IsSelected}"
                                                    ToolTip.Tip="{Binding #Root.DataContext.L[CloseNoteTab]}"
                                                    AutomationProperties.Name="{Binding #Root.DataContext.L[CloseNoteTab]}"
                                                    Width="24"
                                                    Height="24"
                                                    Padding="0"
                                                    Margin="0,2,5,0"
                                                    VerticalAlignment="Top">
                                                <ic:FluentIcon Icon="Dismiss" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel x:Name="NoteTabCommandRegion"
                            Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="{DynamicResource LayerFillColorSubtleBrush}">
                    <Button x:Name="NextNoteTabButton"
                            Click="NextNoteTabButton_OnClick"
                            IsEnabled="False"
                            ToolTip.Tip="{Binding L[NextNoteTabs]}"
                            AutomationProperties.Name="{Binding L[NextNoteTabs]}"
                            Width="40"
                            Height="40"
                            Padding="0"
                            Margin="2,4"
                            VerticalAlignment="Top">
                        <ic:FluentIcon Icon="ChevronRight" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                    <Button x:Name="AddNoteTabButton"
                            Command="{Binding AddNoteCommand}"
                            ToolTip.Tip="{Binding L.NewSecureNote}"
                            AutomationProperties.Name="{Binding L.NewSecureNote}"
                            Width="40"
                            Height="40"
                            Padding="0"
                            Margin="0,4,2,4"
                            VerticalAlignment="Top">
                        <ic:FluentIcon Icon="Add" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                    <Button x:Name="SaveNoteTabButton"
                            Command="{Binding SaveNoteCommand}"
                            IsEnabled="{Binding HasOpenNoteTabs}"
                            ToolTip.Tip="{Binding L.SaveNote}"
                            AutomationProperties.Name="{Binding L.SaveNote}"
                            Width="40"
                            Height="40"
                            Padding="0"
                            Margin="0,4,2,4"
                            VerticalAlignment="Top">
                        <ic:FluentIcon Icon="Save" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                    <Button x:Name="MoreNoteTabButton"
                            ToolTip.Tip="{Binding L.MoreOptions}"
                            AutomationProperties.Name="{Binding L.MoreOptions}"
                            Width="40"
                            Height="40"
                            Padding="0"
                            Margin="0,4,4,4"
                            VerticalAlignment="Top">
                        <ic:FluentIcon Icon="MoreHorizontal" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="{Binding L[SaveAllNotes]}" Command="{Binding SaveAllNoteTabsCommand}" />
                                <MenuItem Header="{Binding L[ImportMarkdown]}" Command="{Binding ImportMarkdownNoteCommand}" IsEnabled="{Binding CanUseFilePicker}" />
                                <MenuItem Header="{Binding L[ExportMarkdown]}" Command="{Binding ExportCurrentNoteMarkdownCommand}" IsEnabled="{Binding HasOpenNoteTabs}" />
                                <MenuItem Header="{Binding InsertNoteImageActionLabel}" Command="{Binding InsertNoteImageCommand}" IsEnabled="{Binding HasOpenNoteTabs}" />
                                <MenuItem Header="{Binding L[ToggleFavorite]}" Command="{Binding ToggleNoteFavoriteCommand}" IsEnabled="{Binding HasOpenNoteTabs}" />
                                <Separator />
                                <MenuItem Header="{Binding L[NoteEditMode]}" Click="SetNoteEditModeMenuItem_OnClick" IsEnabled="{Binding HasOpenNoteTabs}" />
                                <MenuItem Header="{Binding L[NotePreviewMode]}" Click="SetNotePreviewModeMenuItem_OnClick" IsEnabled="{Binding HasOpenNoteTabs}" />
                                <MenuItem Header="{Binding L[NoteSplitMode]}" Click="SetNoteSplitModeMenuItem_OnClick" IsEnabled="{Binding HasOpenNoteTabs}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>

            <Border x:Name="NoteInspectorHeader"
                    Grid.Column="2"
                    IsVisible="{Binding IsNoteInspectorPaneVisible}"
                    Padding="14,0"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,0">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <ic:FluentIcon Icon="Info" FontSize="16" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding L[NoteInformation]}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
