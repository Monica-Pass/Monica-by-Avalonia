<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:local="using:Monica.App"
             xmlns:notes="using:Monica.App.Features.Notes"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.Notes.NoteTreeView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">
    <Border IsVisible="{Binding IsNoteTreePaneVisible}"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,1,0"
            Background="{DynamicResource LayerFillColorDefaultBrush}">
        <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4" Margin="0,0,0,10">
                <TextBox x:Name="NoteSearchBox"
                         Text="{Binding NoteSearchText}"
                         PlaceholderText="{Binding L[NoteSearchWatermark]}"
                         AutomationProperties.Name="{Binding L.Search}"
                         Height="36" />
                <Button x:Name="ClearNoteSearchButton"
                        Grid.Column="1"
                        IsVisible="{Binding HasNoteSearchText}"
                        Command="{Binding ClearNoteSearchCommand}"
                        ToolTip.Tip="{Binding L[ClearNoteSearch]}"
                        AutomationProperties.Name="{Binding L[ClearNoteSearch]}"
                        Width="36"
                        Height="36"
                        Padding="0">
                    <ic:FluentIcon Icon="Dismiss" FontSize="14" />
                </Button>
            </Grid>

            <Border Grid.Row="1"
                    Classes="noteNavigationPivot"
                    Margin="0,0,0,10"
                    Padding="2">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="2">
                    <Button x:Name="NoteFolderNavigationButton"
                            Classes="noteNavigationPivotButton"
                            Classes.accent="{Binding IsNoteFolderNavigation}"
                            Command="{Binding SelectNoteNavigationModeCommand}"
                            CommandParameter="Folders"
                            AutomationProperties.Name="{Binding L.Folders}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                            <ic:FluentIcon Icon="Folder" FontSize="14" />
                            <TextBlock Text="{Binding L.Folders}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NoteTagNavigationButton"
                            Grid.Column="1"
                            Classes="noteNavigationPivotButton"
                            Classes.accent="{Binding IsNoteTagNavigation}"
                            Command="{Binding SelectNoteNavigationModeCommand}"
                            CommandParameter="Tags"
                            AutomationProperties.Name="{Binding L[NoteTagsLabel]}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                            <ic:FluentIcon Icon="Tag" FontSize="14" />
                            <TextBlock Text="{Binding L[NoteTagsLabel]}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <ListBox x:Name="NoteTreeList"
                     Grid.Row="2"
                     ItemsSource="{Binding NoteTreeEntries}"
                     IsVisible="{Binding HasNoteTreeEntries}"
                     SelectionMode="Single"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                    <Style Selector="ListBoxItem /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:NoteTreeEntry">
                        <Grid>
                            <Grid IsVisible="{Binding IsGroup}"
                                  Margin="{Binding Indent}">
                                <Button Classes="noteTreeGroupButton"
                                        Classes.selected="{Binding IsSelected}"
                                        Command="{Binding #Root.DataContext.SelectNoteTreeGroupCommand}"
                                        CommandParameter="{Binding}"
                                        AutomationProperties.Name="{Binding Name}"
                                        HorizontalAlignment="Stretch"
                                        MinHeight="34" />
                                <Grid ColumnDefinitions="24,Auto,*,Auto"
                                      ColumnSpacing="6"
                                      Margin="6,0,10,0"
                                      MinHeight="34"
                                      IsHitTestVisible="False">
                                    <Panel Grid.Column="1" Width="17" Height="17" VerticalAlignment="Center">
                                        <ic:FluentIcon Icon="FolderOpen" FontSize="14" IsVisible="{Binding IsFolderGroup}" />
                                        <ic:FluentIcon Icon="Tag" FontSize="14" IsVisible="{Binding IsTagGroup}" />
                                    </Panel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Name}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               ToolTip.Tip="{Binding Name}" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Count}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <Button Classes="noteTreeExpandButton"
                                        Command="{Binding #Root.DataContext.ToggleNoteTreeGroupCommand}"
                                        CommandParameter="{Binding}"
                                        IsVisible="{Binding HasChildren}"
                                        ToolTip.Tip="{Binding Name}"
                                        AutomationProperties.Name="{Binding Name}"
                                        Width="24"
                                        Height="24"
                                        Padding="0"
                                        Margin="4,5,0,5"
                                        HorizontalAlignment="Left">
                                    <Panel>
                                        <ic:FluentIcon Icon="ChevronDown" FontSize="11" IsVisible="{Binding IsExpanded}" />
                                        <ic:FluentIcon Icon="ChevronRight" FontSize="11" IsVisible="{Binding IsCollapsed}" />
                                    </Panel>
                                </Button>
                            </Grid>
                            <Grid IsVisible="{Binding IsNote}"
                                  Margin="{Binding Indent}">
                                <notes:NoteTreeItemView DataContext="{Binding Item}"
                                                        ViewModel="{Binding #Root.DataContext}" />
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel x:Name="NoteTreeEmptyState"
                        Grid.Row="2"
                        IsVisible="{Binding HasNoteTreeEntries, Converter={x:Static local:BoolConverters.Not}}"
                        Spacing="10"
                        Margin="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <ic:FluentIcon Icon="Note"
                               FontSize="32"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center" />
                <TextBlock Text="{Binding NoteTreeEmptyText}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="220" />
                <Button x:Name="EmptyNoteTreeAddButton"
                        IsVisible="{Binding ShowAddNoteInEmptyTree}"
                        Command="{Binding AddNoteCommand}"
                        AutomationProperties.Name="{Binding L.NewSecureNote}"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ic:FluentIcon Icon="Add" FontSize="16" />
                        <TextBlock Text="{Binding L.NewSecureNote}" />
                    </StackPanel>
                </Button>
                <Button IsVisible="{Binding ShowClearNoteSearchInEmptyTree}"
                        Command="{Binding ClearNoteSearchCommand}"
                        AutomationProperties.Name="{Binding L[ClearNoteSearch]}"
                        Content="{Binding L[ClearNoteSearch]}"
                        HorizontalAlignment="Center" />
            </StackPanel>

            <Border Grid.Row="3"
                    IsVisible="{Binding IsNoteFolderNavigation}"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="0,10,0,0"
                    Margin="0,8,0,0">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="4">
                    <TextBox x:Name="NewNoteFolderNameBox"
                             Text="{Binding NewNoteFolderName}"
                             PlaceholderText="{Binding L.NewFolder}"
                             AutomationProperties.Name="{Binding L.NewFolder}"
                             Height="32"
                             MinWidth="0" />
                    <Button x:Name="CreateNoteFolderButton"
                            Grid.Column="1"
                            Classes="noteFolderManagementButton"
                            Command="{Binding CreateNoteFolderCommand}"
                            ToolTip.Tip="{Binding L.CreateFolder}"
                            AutomationProperties.Name="{Binding L.CreateFolder}"
                            Width="32"
                            Height="32"
                            Padding="0">
                        <ic:FluentIcon Icon="FolderAdd" FontSize="14" />
                    </Button>
                    <Button x:Name="RenameNoteFolderButton"
                            Grid.Column="2"
                            Classes="noteFolderManagementButton"
                            Command="{Binding RenameSelectedNoteFolderCommand}"
                            IsEnabled="{Binding CanManageSelectedNoteFolder}"
                            ToolTip.Tip="{Binding L.RenameFolder}"
                            AutomationProperties.Name="{Binding L.RenameFolder}"
                            Width="32"
                            Height="32"
                            Padding="0">
                        <ic:FluentIcon Icon="Edit" FontSize="14" />
                    </Button>
                    <Button x:Name="DeleteNoteFolderButton"
                            Grid.Column="3"
                            Classes="noteFolderManagementButton"
                            Command="{Binding DeleteSelectedNoteFolderCommand}"
                            IsEnabled="{Binding CanManageSelectedNoteFolder}"
                            ToolTip.Tip="{Binding L.DeleteFolder}"
                            AutomationProperties.Name="{Binding L.DeleteFolder}"
                            Width="32"
                            Height="32"
                            Padding="0">
                        <ic:FluentIcon Icon="Delete" FontSize="14" />
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
