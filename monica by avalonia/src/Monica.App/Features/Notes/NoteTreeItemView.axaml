<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:models="using:Monica.Core.Models"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.Notes.NoteTreeItemView"
             x:Name="Root"
             x:DataType="models:SecureItem">
    <Grid ColumnDefinitions="*,Auto"
          MinHeight="56"
          HorizontalAlignment="Stretch">
        <Button Classes="noteTreeItemButton"
                Grid.ColumnSpan="2"
                Command="{Binding #Root.ViewModel.OpenNoteCommand}"
                CommandParameter="{Binding}"
                AutomationProperties.Name="{Binding Title}"
                MinHeight="56" />

        <Grid Margin="12,8,46,8"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="9"
              HorizontalAlignment="Stretch"
              IsHitTestVisible="False">
            <ic:FluentIcon Icon="Document" FontSize="16" VerticalAlignment="Top" Margin="0,2,0,0" />
            <StackPanel Grid.Column="1" Spacing="2" MinWidth="0">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <TextBlock Text="{Binding Title}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               MinWidth="0" />
                    <ic:FluentIcon Grid.Column="1"
                                   Icon="Star"
                                   FontSize="12"
                                   IsVisible="{Binding IsFavorite}"
                                   VerticalAlignment="Center" />
                </Grid>
                <TextBlock Text="{Binding Notes}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <Button x:Name="NoteItemMoreButton"
                Grid.Column="1"
                ToolTip.Tip="{Binding #Root.ViewModel.L.MoreOptions}"
                AutomationProperties.Name="{Binding #Root.ViewModel.L.MoreOptions}"
                Width="40"
                Height="40"
                Padding="0"
                Margin="2,4,4,0"
                VerticalAlignment="Top">
            <ic:FluentIcon Icon="MoreHorizontal" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <Button.Flyout>
                <MenuFlyout>
                    <MenuItem Header="{Binding #Root.ViewModel.L.Open}"
                              Command="{Binding #Root.ViewModel.OpenNoteCommand}"
                              CommandParameter="{Binding}" />
                    <MenuItem Header="{Binding #Root.ViewModel.L[ToggleFavorite]}"
                              Command="{Binding #Root.ViewModel.ToggleNoteFavoriteCommand}"
                              CommandParameter="{Binding}" />
                    <Separator />
                    <MenuItem Header="{Binding #Root.ViewModel.L.MoveToRecycleBin}"
                              Command="{Binding #Root.ViewModel.DeleteNoteCommand}"
                              CommandParameter="{Binding}" />
                </MenuFlyout>
            </Button.Flyout>
        </Button>
    </Grid>
</UserControl>
