<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Monica.App"
             xmlns:views="using:Monica.App.Features.Generator"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.Generator.GeneratorWorkspaceView"
             x:Name="GeneratorWorkspaceRoot"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <StyleInclude Source="/Features/Generator/GeneratorStyles.axaml" />
    </UserControl.Styles>

    <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsGenerator}}"
          RowDefinitions="Auto,*"
          HorizontalAlignment="Stretch"
          ClipToBounds="True">
        <Border BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="0,0,0,12"
                Margin="0,0,0,12">
            <Grid x:Name="GeneratorHeaderGrid" ColumnDefinitions="*" MinHeight="56">
                <StackPanel x:Name="GeneratorHeaderTitle" MinWidth="0" VerticalAlignment="Center">
                    <TextBlock Classes="workspacePageTitle" Text="{Binding L.PasswordGenerator}" />
                    <TextBlock Text="{Binding GeneratedPasswordStrengthText}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="GeneratorContentGrid"
              Grid.Row="1"
              ColumnDefinitions="*,340"
              RowDefinitions="*"
              ColumnSpacing="14"
              RowSpacing="14"
              MinWidth="0">
            <views:GeneratorResultView x:Name="GeneratorResultView" />
            <views:GeneratorOptionsView x:Name="GeneratorOptionsView" Grid.Column="1" />
        </Grid>
    </Grid>
</UserControl>
