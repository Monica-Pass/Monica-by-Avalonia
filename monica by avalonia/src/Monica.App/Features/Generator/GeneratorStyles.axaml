<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Border.generatorPageHeader">
        <Setter Property="BorderBrush" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="0,0,0,14" />
        <Setter Property="Margin" Value="0,0,0,14" />
    </Style>
    <Style Selector="Border.generatorStatusChip">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.generatorResultPanel">
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Border.generatorOptionsPanel">
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
    </Style>
    <Style Selector="Border.generatorOutputSurface">
        <Setter Property="Padding" Value="20" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
    </Style>
    <Style Selector="Border.generatorHistorySurface">
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.generatorPasswordBox">
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="MinHeight" Value="170" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
</Styles>
