<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:local="using:Monica.App"
             xmlns:models="using:Monica.Core.Models"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.Archive.ArchiveWorkspaceView"
             x:Name="ArchiveWorkspaceRoot"
             x:DataType="vm:MainWindowViewModel">
<UserControl.Styles>
    <StyleInclude Source="/Features/Archive/ArchiveStyles.axaml" />
</UserControl.Styles>
<Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsArchive}}" RowDefinitions="Auto,*" HorizontalAlignment="Stretch" ClipToBounds="True">
    <Border x:Name="ArchiveRecoveryCommandSurface" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,8">
        <Grid x:Name="ArchiveHeaderGrid" ColumnDefinitions="*,320,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" MinHeight="56">
            <StackPanel MinWidth="0" VerticalAlignment="Center">
                <TextBlock Classes="workspacePageTitle" Text="{Binding L.Archive}" />
                <TextBlock Text="{Binding ArchivedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <Grid x:Name="ArchiveSearchRegion" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="6" VerticalAlignment="Center">
                <TextBox x:Name="ArchiveSearchBox" PlaceholderText="{Binding L.Search}" Text="{Binding ArchiveSearchText}" AutomationProperties.Name="{Binding L.Search}" />
                <Button x:Name="ArchiveSearchClearButton" Grid.Column="1" Classes="workspaceCommand" Command="{Binding ClearArchiveSearchCommand}" IsVisible="{Binding HasArchiveSearchText}" ToolTip.Tip="{Binding L[Clear]}" AutomationProperties.Name="{Binding L[Clear]}" Width="36" Height="36" Padding="0">
                    <ic:FluentIcon Icon="Dismiss" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
            </Grid>
            <StackPanel x:Name="ArchiveHeaderCommands" Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="ArchivePageMenuButton"
                        Classes="workspaceCommand"
                        ToolTip.Tip="{Binding L.MoreOptions}"
                        AutomationProperties.Name="{Binding L.MoreOptions}"
                        Width="40"
                        Height="40"
                        Padding="0">
                    <ic:FluentIcon Icon="MoreHorizontal" FontSize="18" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem x:Name="OpenPasswordsFromArchiveMenuItem" Header="{Binding L.Passwords}" Command="{Binding SelectSectionCommand}" CommandParameter="Passwords">
                                <MenuItem.Icon><ic:FluentIcon Icon="Key" FontSize="16" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem x:Name="OpenRecycleBinFromArchiveMenuItem" Header="{Binding L.RecycleBin}" Command="{Binding SelectSectionCommand}" CommandParameter="RecycleBin">
                                <MenuItem.Icon><ic:FluentIcon Icon="Delete" FontSize="16" /></MenuItem.Icon>
                            </MenuItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>
    </Border>

    <Grid x:Name="ArchiveMasterDetailGrid" Grid.Row="1" ColumnDefinitions="300,*" MinWidth="0">
        <Border x:Name="ArchiveListRegion" Classes="archiveFilterRail" ClipToBounds="True">
            <Grid RowDefinitions="Auto,Auto,*">
                <Grid Margin="14,12,14,8" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <StackPanel Spacing="3">
                        <TextBlock Classes="workspaceSectionLabel" Text="{Binding L.Archive}" />
                        <TextBlock Text="{Binding ArchivedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                    <CheckBox x:Name="ArchiveSelectAllCheckBox"
                              Grid.Column="1"
                              IsChecked="{Binding AreAllFilteredArchivedPasswordsSelected}"
                              IsEnabled="{Binding HasFilteredArchivedPasswords}"
                              ToolTip.Tip="{Binding SelectAllVisiblePasswordsText}"
                              AutomationProperties.Name="{Binding SelectAllVisiblePasswordsText}"
                              VerticalAlignment="Center" />
                </Grid>
                <Border x:Name="ArchiveSelectionBar"
                        Grid.Row="1"
                        IsVisible="{Binding HasSelectedArchivedPasswords}"
                        Margin="0"
                        Padding="14,8"
                        CornerRadius="0"
                        Background="{DynamicResource LayerFillColorSubtleBrush}"
                        BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Text="{Binding SelectedArchivedPasswordCountText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button x:Name="UnarchiveSelectedPasswordsButton"
                                    Classes="workspacePrimaryCommand"
                                    Command="{Binding UnarchiveSelectedArchivedPasswordsCommand}"
                                    ToolTip.Tip="{Binding L.UnarchivePassword}"
                                    AutomationProperties.Name="{Binding L.UnarchivePassword}"
                                    Padding="8,4">
                                <ic:FluentIcon Icon="ArrowUndo" FontSize="16" />
                            </Button>
                            <Button x:Name="ClearArchiveSelectionButton"
                                    Classes="workspaceCommand"
                                    Command="{Binding ClearArchivedPasswordSelectionCommand}"
                                    ToolTip.Tip="{Binding L.Cancel}"
                                    AutomationProperties.Name="{Binding L.Cancel}"
                                    Padding="8,4">
                                <ic:FluentIcon Icon="Dismiss" FontSize="16" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
                <Grid Grid.Row="2">
                    <StackPanel IsVisible="{Binding !HasFilteredArchivedPasswords}" HorizontalAlignment="Left" VerticalAlignment="Top" Spacing="10" Margin="24" Width="240">
                        <ic:FluentIcon Icon="Archive" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding ArchivedPasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ArchiveEmptyStateText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" />
                        <Button x:Name="EmptyArchiveClearSearchButton" Classes="workspaceCommand" Command="{Binding ClearArchiveSearchCommand}" IsVisible="{Binding ShowClearArchiveSearchInEmptyState}" ToolTip.Tip="{Binding L[Clear]}" AutomationProperties.Name="{Binding L[Clear]}" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="Dismiss" FontSize="12" /><TextBlock Text="{Binding L[Clear]}" /></StackPanel>
                        </Button>
                        <Button Classes="workspaceCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Passwords" ToolTip.Tip="{Binding L.Passwords}" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="Key" FontSize="16" />
                                <TextBlock Text="{Binding L.Passwords}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <ListBox x:Name="ArchivePasswordList" Classes="archiveRecoveryList" ItemsSource="{Binding FilteredArchivedPasswords}" SelectedItem="{Binding SelectedArchivedPassword}" IsVisible="{Binding HasFilteredArchivedPasswords}" SelectionMode="Single" AutomationProperties.Name="{Binding L.Archive}" Margin="8,0,8,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:PasswordEntry">
                                <Border Classes="archiveRecoveryRow">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{Binding #ArchiveWorkspaceRoot.DataContext.L.UnarchivePassword}" Command="{Binding #ArchiveWorkspaceRoot.DataContext.UnarchivePasswordCommand}" CommandParameter="{Binding}" />
                                            <MenuItem Header="{Binding #ArchiveWorkspaceRoot.DataContext.L.MoveToRecycleBin}" Command="{Binding #ArchiveWorkspaceRoot.DataContext.DeletePasswordCommand}" CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                        <Button Classes="archiveRecoveryRowButton"
                                                Command="{Binding #ArchiveWorkspaceRoot.DataContext.ShowArchivedPasswordDetailsCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{Binding Title}"
                                                AutomationProperties.Name="{Binding Title}">
                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="2">
                                                <Border Grid.RowSpan="3" Width="38" Height="38" CornerRadius="19" Background="{DynamicResource AccentFillColorDefaultBrush}" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding AvatarText}" Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Username}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                            </Grid>
                                        </Button>
                                        <CheckBox Grid.Column="1"
                                                  IsChecked="{Binding IsSelected}"
                                                  ToolTip.Tip="{Binding #ArchiveWorkspaceRoot.DataContext.SelectPasswordItemsText}"
                                                  AutomationProperties.Name="{Binding #ArchiveWorkspaceRoot.DataContext.SelectPasswordItemsText}"
                                                  VerticalAlignment="Center"
                                                  Margin="4" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="ArchiveDetailRegion" Grid.Column="1" Classes="archiveInspector" Padding="28,22" MinWidth="0" Focusable="True">
            <Grid>
                <ScrollViewer IsVisible="{Binding HasSelectedArchivedPassword}" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="18">
                    <Button x:Name="BackToArchiveListButton" Classes="workspaceCommand" Command="{Binding CloseArchivedPasswordDetailsCommand}" ToolTip.Tip="{Binding L[Back]}" AutomationProperties.Name="{Binding L[Back]}" HorizontalAlignment="Left" IsVisible="False">
                        <StackPanel Orientation="Horizontal" Spacing="6"><ic:FluentIcon Icon="ArrowLeft" FontSize="16" /><TextBlock Text="{Binding L[Back]}" /></StackPanel>
                    </Button>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Border Width="54" Height="54" CornerRadius="27" Background="{DynamicResource AccentFillColorDefaultBrush}">
                            <TextBlock Text="{Binding SelectedArchivedPassword.AvatarText}" Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" FontWeight="SemiBold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" MinWidth="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedArchivedPassword.Title}" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SelectedArchivedPassword.Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                        <Button x:Name="ArchiveDetailPrimaryActionButton" Classes="workspacePrimaryCommand" Command="{Binding UnarchivePasswordCommand}" CommandParameter="{Binding SelectedArchivedPassword}" ToolTip.Tip="{Binding L.UnarchivePassword}" AutomationProperties.Name="{Binding L.UnarchivePassword}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="ArrowUndo" FontSize="18" />
                                <TextBlock Text="{Binding L.UnarchivePassword}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ArchiveDetailMenuButton"
                                Classes="workspaceCommand"
                                ToolTip.Tip="{Binding L.MoreOptions}"
                                AutomationProperties.Name="{Binding L.MoreOptions}"
                                Width="40"
                                Height="40"
                                Padding="0">
                            <ic:FluentIcon Icon="MoreHorizontal" FontSize="18" />
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem x:Name="OpenArchivedPasswordDetailsMenuItem" Header="{Binding L.PasswordDetails}" Command="{Binding ShowPasswordDetailsCommand}" CommandParameter="{Binding SelectedArchivedPassword}">
                                        <MenuItem.Icon><ic:FluentIcon Icon="Info" FontSize="16" /></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem x:Name="MoveArchivedPasswordToRecycleBinMenuItem" Header="{Binding L.MoveToRecycleBin}" Command="{Binding DeletePasswordCommand}" CommandParameter="{Binding SelectedArchivedPassword}">
                                        <MenuItem.Icon><ic:FluentIcon Icon="Delete" FontSize="16" /></MenuItem.Icon>
                                    </MenuItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>
                    <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="14">
                        <TextBlock Classes="workspaceDetailLabel" Text="{Binding L.Username}" />
                        <TextBlock Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedArchivedPassword.Username}" />
                        <TextBlock Grid.Row="1" Classes="workspaceDetailLabel" Text="{Binding L.Website}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedArchivedPassword.Website}" />
                        <TextBlock Grid.Row="2" Classes="workspaceDetailLabel" Text="{Binding L.CreatedAt}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedArchivedPassword.CreatedAt, StringFormat='{}{0:g}'}" />
                        <TextBlock Grid.Row="3" Classes="workspaceDetailLabel" Text="{Binding L.UpdatedAt}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedArchivedPassword.UpdatedAt, StringFormat='{}{0:g}'}" />
                        <TextBlock Grid.Row="4" Classes="workspaceDetailLabel" Text="{Binding L.Archive}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Classes="workspaceDetailValue" Text="{Binding SelectedArchivedPassword.ArchivedAt, StringFormat='{}{0:g}'}" />
                    </Grid>
                </StackPanel>
                </ScrollViewer>
                <StackPanel IsVisible="{Binding !HasSelectedArchivedPassword}" Spacing="10" Width="260" Margin="24" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <ic:FluentIcon Icon="Archive" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding ArchivedPasswordCountText}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Grid>
</UserControl>
