<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.Unlock.UnlockView"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="Grid.unlockSurface TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
        <Style Selector="TextBlock.unlockDescription">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="LineHeight" Value="20" />
        </Style>
        <Style Selector="TextBlock.unlockFieldLabel">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBox.unlockInput">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="PlaceholderForeground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBox.unlockInput:pointerover, TextBox.unlockInput:focus">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        </Style>
        <Style Selector="Button.unlockRevealCommand">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.unlockPrimaryCommand">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LayerFillColorAltBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="Button.unlockPrimaryCommand:pointerover, Button.unlockPrimaryCommand:pressed">
            <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LayerFillColorAltBrush}" />
        </Style>
        <Style Selector="Button.unlockPrimaryCommand:disabled">
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <Style Selector="Border.unlockFeedback">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.unlockFeedback.error">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid Classes="unlockSurface"
          Background="{DynamicResource LayerFillColorDefaultBrush}"
          ClipToBounds="True">
        <StackPanel MaxWidth="440"
                    Margin="32,24"
                    Spacing="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Image Source="/Assets/Logo.png"
                   Width="56"
                   Height="56"
                   HorizontalAlignment="Center" />
            <TextBlock Text="{Binding LoginTitle}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
            <TextBlock Classes="unlockDescription" Text="{Binding LoginDescription}" />
            <Border IsVisible="{Binding HasLegacyVaultImportPrompt}"
                    Padding="12"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource LayerFillColorSubtleBrush}">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding L.LegacyVaultDetected}" FontWeight="SemiBold" />
                    <TextBlock Classes="unlockDescription"
                               Text="{Binding LegacyVaultImportPromptText}"
                               TextAlignment="Left" />
                </StackPanel>
            </Border>
            <StackPanel Spacing="6">
                <TextBlock x:Name="MasterPasswordLabel"
                           Classes="unlockFieldLabel"
                           Text="{Binding L.MasterPasswordWatermark}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBox x:Name="MasterPasswordInput"
                             Classes="unlockInput"
                             PasswordChar="{Binding MasterPasswordMaskChar}"
                             PlaceholderText="{Binding L.MasterPasswordWatermark}"
                             Text="{Binding MasterPassword, Mode=TwoWay}"
                             IsEnabled="{Binding !IsUnlocking}"
                             AutomationProperties.Name="{Binding L.MasterPasswordWatermark}"
                             AutomationProperties.HelpText="{Binding MasterPasswordPrivacyNotice}" />
                    <Button x:Name="ToggleMasterPasswordVisibilityButton"
                            Grid.Column="1"
                            Classes="unlockRevealCommand"
                            Command="{Binding ToggleMasterPasswordVisibilityCommand}"
                            IsEnabled="{Binding !IsUnlocking}"
                            ToolTip.Tip="{Binding ToggleMasterPasswordVisibilityLabel}"
                            AutomationProperties.Name="{Binding ToggleMasterPasswordVisibilityLabel}">
                        <ic:FluentIcon Icon="Eye" FontSize="18" />
                    </Button>
                </Grid>
            </StackPanel>
            <StackPanel IsVisible="{Binding !IsVaultInitialized}" Spacing="6">
                <TextBlock x:Name="ConfirmMasterPasswordLabel"
                           Classes="unlockFieldLabel"
                           Text="{Binding L.ConfirmMasterPasswordWatermark}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBox x:Name="ConfirmMasterPasswordInput"
                             Classes="unlockInput"
                             PasswordChar="{Binding ConfirmMasterPasswordMaskChar}"
                             PlaceholderText="{Binding L.ConfirmMasterPasswordWatermark}"
                             Text="{Binding ConfirmMasterPassword, Mode=TwoWay}"
                             IsEnabled="{Binding !IsUnlocking}"
                             AutomationProperties.Name="{Binding L.ConfirmMasterPasswordWatermark}" />
                    <Button x:Name="ToggleConfirmMasterPasswordVisibilityButton"
                            Grid.Column="1"
                            Classes="unlockRevealCommand"
                            Command="{Binding ToggleConfirmMasterPasswordVisibilityCommand}"
                            IsEnabled="{Binding !IsUnlocking}"
                            ToolTip.Tip="{Binding ToggleConfirmMasterPasswordVisibilityLabel}"
                            AutomationProperties.Name="{Binding ToggleConfirmMasterPasswordVisibilityLabel}">
                        <ic:FluentIcon Icon="Eye" FontSize="18" />
                    </Button>
                </Grid>
            </StackPanel>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <ic:FluentIcon Icon="LockClosed"
                               FontSize="16"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,2,0,0" />
                <TextBlock Grid.Column="1"
                           Classes="unlockDescription"
                           Text="{Binding MasterPasswordPrivacyNotice}"
                           TextAlignment="Left" />
            </Grid>
            <Button x:Name="UnlockButton"
                    Classes="unlockPrimaryCommand"
                    Command="{Binding UnlockCommand}"
                    IsDefault="True"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    AutomationProperties.Name="{Binding LoginButtonText}">
                <TextBlock Text="{Binding LoginButtonText}"
                           Foreground="{DynamicResource LayerFillColorAltBrush}" />
            </Button>
            <ProgressBar x:Name="UnlockProgress"
                         IsVisible="{Binding IsUnlocking}"
                         IsIndeterminate="True"
                         Height="4" />
            <Border Classes="unlockFeedback"
                    Classes.error="{Binding HasUnlockError}"
                    IsVisible="{Binding HasUnlockStatusMessage}">
                <TextBlock Classes="unlockDescription"
                           Text="{Binding StatusMessage}"
                           TextAlignment="Left" />
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
