<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.SecurityAnalysis.SecurityAnalysisInspectorView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer x:Name="SecurityIssueDetailScrollViewer" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid>
            <StackPanel IsVisible="{Binding HasSelectedSecurityIssue}" Spacing="18">
                <Button x:Name="BackToSecurityIssueListButton" Command="{Binding ShowSecurityIssueListCommand}" HorizontalAlignment="Left" ToolTip.Tip="{Binding L[BackToSecurityIssues]}" AutomationProperties.Name="{Binding L[BackToSecurityIssues]}">
                    <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="ArrowLeft" FontSize="18" /><TextBlock Text="{Binding L[BackToSecurityIssues]}" /></StackPanel>
                </Button>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Border Width="54" Height="54" CornerRadius="27" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                        <ic:FluentIcon Icon="Shield" FontSize="24" Foreground="{DynamicResource AccentFillColorDefaultBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedSecurityIssue.Title}" FontSize="22" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding SelectedSecurityIssue.Subtitle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
                <WrapPanel>
                    <Border Classes="workspaceStatusChip" Margin="0,0,8,8"><TextBlock Text="{Binding SelectedSecurityIssue.Category}" FontSize="12" FontWeight="SemiBold" /></Border>
                    <Border Classes="workspaceStatusChip" Margin="0,0,8,8"><TextBlock Text="{Binding SelectedSecurityIssue.Severity}" FontSize="12" /></Border>
                </WrapPanel>
                <WrapPanel>
                    <Button Classes="workspacePrimaryCommand" Command="{Binding ShowPasswordDetailsCommand}" CommandParameter="{Binding SelectedSecurityIssue.Entry}" Margin="0,0,8,8" AutomationProperties.Name="{Binding L.PasswordDetails}" ToolTip.Tip="{Binding L.PasswordDetails}">
                        <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="Info" FontSize="18" /><TextBlock Text="{Binding L.PasswordDetails}" /></StackPanel>
                    </Button>
                    <Button Classes="workspaceCommand" Command="{Binding EditPasswordCommand}" CommandParameter="{Binding SelectedSecurityIssue.Entry}" Margin="0,0,0,8" AutomationProperties.Name="{Binding L.EditPassword}" ToolTip.Tip="{Binding L.EditPassword}">
                        <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="Edit" FontSize="18" /><TextBlock Text="{Binding L.EditPassword}" /></StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>
            <StackPanel IsVisible="{Binding !HasSelectedSecurityIssue}" Spacing="10" Margin="24" Width="260" HorizontalAlignment="Left">
                <ic:FluentIcon Icon="Shield" FontSize="34" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding SecurityIssueSearchResultText}" TextAlignment="Center" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
