<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Monica.App"
             xmlns:views="using:Monica.App.Features.SecurityAnalysis"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.SecurityAnalysis.SecurityAnalysisWorkspaceView"
             x:DataType="vm:MainWindowViewModel">
    <Grid IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsSecurityAnalysis}}"
          RowDefinitions="Auto,*"
          HorizontalAlignment="Stretch"
          ClipToBounds="True">
        <Border Classes="workspacePageHeader">
            <Grid x:Name="SecurityHeaderGrid" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="12" RowSpacing="10">
                <StackPanel MinWidth="0" VerticalAlignment="Top">
                    <TextBlock Classes="workspacePageTitle" Text="{Binding L.SecurityAnalysis}" />
                    <TextBlock Classes="workspacePageSubtitle"
                               Text="{Binding L.SecurityAnalysisSubtitle}"
                               MaxWidth="760"
                               TextWrapping="Wrap" />
                </StackPanel>
                <views:SecurityAnalysisCommandBarView x:Name="SecurityAnalysisCommandBar" Grid.Column="1" MinWidth="280" />
                <ScrollViewer x:Name="SecuritySummaryRegion" Grid.Row="1" Grid.ColumnSpan="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding SecuritySummaryItems}" HorizontalAlignment="Left">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SecuritySummaryItem">
                                <Border Width="148" MinHeight="82" Margin="0,0,8,0" Padding="10" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource LayerFillColorDefaultBrush}">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                        <TextBlock Text="{Binding Value}" FontSize="20" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12" MaxLines="2" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid x:Name="SecurityAnalysisLayoutGrid" Grid.Row="1" ColumnDefinitions="360,*" RowDefinitions="*" ColumnSpacing="16" MinWidth="0">
            <Border x:Name="SecurityIssueListRegion" Classes="workspaceSidebar" ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <views:SecurityAnalysisFilterPaneView x:Name="SecurityAnalysisFilterPane" />
                    <views:SecurityAnalysisIssueListView x:Name="SecurityAnalysisIssueListView" Grid.Row="1" />
                </Grid>
            </Border>
            <Border x:Name="SecurityIssueDetailRegion" Grid.Column="1" Classes="workspacePane" Padding="20" MinWidth="0" Focusable="True">
                <views:SecurityAnalysisInspectorView x:Name="SecurityAnalysisInspectorView" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
