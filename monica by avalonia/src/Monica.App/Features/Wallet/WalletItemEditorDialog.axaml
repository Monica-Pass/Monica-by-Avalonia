<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.Wallet.WalletItemEditorDialog"
             x:DataType="vm:WalletItemEditorViewModel"
             mc:Ignorable="d"
             d:DesignWidth="560"
             d:DesignHeight="640">
    <UserControl.Styles>
        <Style Selector="TextBox"><Setter Property="MinHeight" Value="40" /></Style>
        <Style Selector="ComboBox"><Setter Property="MinHeight" Value="40" /></Style>
    </UserControl.Styles>
    <ScrollViewer x:Name="WalletEditorFormScrollViewer" MaxHeight="640">
        <StackPanel x:Name="WalletEditorPrimaryForm" Width="520" Spacing="12">
            <ComboBox ItemsSource="{Binding WalletTypeOptions}"
                      SelectedItem="{Binding SelectedWalletType}"
                      HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:WalletTypeChoice">
                        <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBox Text="{Binding Title}" PlaceholderText="{Binding L.PasswordTitle}" />
            <CheckBox Content="{Binding L.Favorite}" IsChecked="{Binding IsFavorite}" />

            <StackPanel Spacing="10" IsVisible="{Binding IsDocument}">
                <ComboBox ItemsSource="{Binding DocumentTypeOptions}"
                          SelectedItem="{Binding SelectedDocumentType}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:WalletChoice">
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                        <TextBox x:Name="DocumentNumberInput"
                                 Text="{Binding DocumentNumber}"
                                 PasswordChar="{Binding DocumentNumberMaskChar}"
                                 PlaceholderText="{Binding L.DocumentNumber}"
                                 AutomationProperties.Name="{Binding L.DocumentNumber}" />
                        <Button x:Name="ToggleDocumentNumberVisibilityButton"
                                Grid.Column="1"
                                Classes="workspaceCommand"
                                Command="{Binding ToggleDocumentNumberVisibilityCommand}"
                                ToolTip.Tip="{Binding DocumentNumberVisibilityLabel}"
                                AutomationProperties.Name="{Binding DocumentNumberVisibilityLabel}"
                                Width="40"
                                Height="40"
                                Padding="0">
                            <ic:FluentIcon Icon="Eye" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                    </Grid>
                    <TextBox Grid.Column="1" Text="{Binding FullName}" PlaceholderText="{Binding L.FullName}" />
                    <TextBox Grid.Row="1" Text="{Binding IssuedDate}" PlaceholderText="{Binding L.IssuedDate}" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ExpiryDate}" PlaceholderText="{Binding L.ExpiryDate}" />
                    <TextBox Grid.Row="2" Text="{Binding IssuedBy}" PlaceholderText="{Binding L.IssuedBy}" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Nationality}" PlaceholderText="{Binding L.Nationality}" />
                </Grid>
                <TextBox Text="{Binding AdditionalInfo}" PlaceholderText="{Binding L.AdditionalInfo}" AcceptsReturn="True" MinHeight="64" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="10" IsVisible="{Binding IsBankCard}">
                <ComboBox ItemsSource="{Binding CardTypeOptions}"
                          SelectedItem="{Binding SelectedCardType}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:WalletChoice">
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                    <TextBox x:Name="CardNumberInput"
                             Text="{Binding CardNumber}"
                             PasswordChar="{Binding CardNumberMaskChar}"
                             PlaceholderText="{Binding L.CardNumber}"
                             AutomationProperties.Name="{Binding L.CardNumber}" />
                    <Button x:Name="ToggleCardNumberVisibilityButton"
                            Grid.Column="1"
                            Classes="workspaceCommand"
                            Command="{Binding ToggleCardNumberVisibilityCommand}"
                            ToolTip.Tip="{Binding CardNumberVisibilityLabel}"
                            AutomationProperties.Name="{Binding CardNumberVisibilityLabel}"
                            Width="40"
                            Height="40"
                            Padding="0">
                        <ic:FluentIcon Icon="Eye" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </Grid>
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                    <TextBox Text="{Binding CardholderName}" PlaceholderText="{Binding L.CardholderName}" />
                    <TextBox Grid.Column="1" Text="{Binding BankName}" PlaceholderText="{Binding L.BankName}" />
                    <TextBox Grid.Row="1" Text="{Binding ExpiryMonth}" PlaceholderText="{Binding L.ExpiryMonth}" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ExpiryYear}" PlaceholderText="{Binding L.ExpiryYear}" />
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                        <TextBox x:Name="CardCvvInput"
                                 Text="{Binding Cvv}"
                                 PasswordChar="{Binding CvvMaskChar}"
                                 PlaceholderText="{Binding L.CreditCardCvv}"
                                 AutomationProperties.Name="{Binding L.CreditCardCvv}" />
                        <Button x:Name="ToggleCardCvvVisibilityButton"
                                Grid.Column="1"
                                Classes="workspaceCommand"
                                Command="{Binding ToggleCvvVisibilityCommand}"
                                ToolTip.Tip="{Binding CvvVisibilityLabel}"
                                AutomationProperties.Name="{Binding CvvVisibilityLabel}"
                                Width="40"
                                Height="40"
                                Padding="0">
                            <ic:FluentIcon Icon="Eye" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                    </Grid>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Brand}" PlaceholderText="{Binding L.CardBrand}" />
                </Grid>
                <TextBox Text="{Binding BillingAddress}" PlaceholderText="{Binding L.BillingAddress}" AcceptsReturn="True" MinHeight="64" TextWrapping="Wrap" />
            </StackPanel>

            <TextBox Text="{Binding ImagePathsText}" PlaceholderText="{Binding L.ImagePathsWatermark}" AcceptsReturn="True" MinHeight="72" TextWrapping="Wrap" />
            <TextBlock Text="{Binding L.ImagePathsDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap" />
            <TextBox Text="{Binding Notes}" PlaceholderText="{Binding L.Notes}" AcceptsReturn="True" MinHeight="72" TextWrapping="Wrap" />
            <TextBlock Text="{Binding ValidationMessage}" Foreground="{DynamicResource SystemFillColorCriticalBrush}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
