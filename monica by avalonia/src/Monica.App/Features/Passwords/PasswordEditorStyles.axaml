<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="TextBlock.editorLabel">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>
    <Style Selector="TextBlock.editorHint">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="Border.editorSection">
        <Setter Property="Padding" Value="4,4,4,16" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderBrush" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="TextBox.editorInput">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ComboBox.editorInput">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Expander.editorExpander">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
</Styles>
