<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="Button.passwordPrimaryCommand">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Foreground" Value="#101010" />
    </Style>
    <Style Selector="Button.passwordCommand">
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="7,5" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.passwordInlineCommand">
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="ToggleButton.passwordFilterChip">
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="7,4" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="ToggleButton.passwordFilterChip:checked">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
    </Style>
    <Style Selector="Border.passwordChromeToolbar">
        <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8" />
    </Style>
    <Style Selector="Border.passwordFolderStrip">
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="0,2,0,8" />
    </Style>
    <Style Selector="Border.passwordSidebar">
        <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Padding" Value="10,8" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="62" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem:selected">
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem:selected /template/ Border#SelectionIndicator">
        <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem:selected /template/ Border#SelectedPipe">
        <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem:selected /template/ Rectangle#SelectionIndicator">
        <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="ListBox.passwordFolderList ListBoxItem">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBox.passwordFolderList ListBoxItem:selected">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
    </Style>
    <Style Selector="ListBox.passwordFolderBar ListBoxItem">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Margin" Value="0,0,4,0" />
        <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.passwordFolderBar ListBoxItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
    </Style>
    <Style Selector="ListBox.passwordFolderBar ListBoxItem:selected">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
</Styles>
