<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="Button.passwordPrimaryCommand">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource LayerFillColorAltBrush}" />
    </Style>
    <Style Selector="Button.passwordCommand">
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="7,5" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.passwordInlineCommand">
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="ToggleButton.passwordFilterOption">
        <Setter Property="MinWidth" Value="140" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="9,6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    <Style Selector="ToggleButton.passwordFilterOption:checked">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
    </Style>
    <Style Selector="Border.passwordChromeToolbar">
        <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="8" />
    </Style>
    <Style Selector="Border.passwordFolderNavigationRegion">
        <Setter Property="MinWidth" Value="0" />
    </Style>
    <Style Selector="Border.passwordFolderNavigation">
        <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Padding" Value="12,8" />
    </Style>
    <Style Selector="ListBox.passwordFolderNavigationList ListBoxItem">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBox.passwordFolderNavigationList ListBoxItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
    </Style>
    <Style Selector="ListBox.passwordFolderNavigationList ListBoxItem:selected">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1,0,0,0" />
    </Style>
    <Style Selector="Border.passwordDetailRegion">
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Border.passwordSidebar">
        <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Padding" Value="10,8" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="62" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem:selected">
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem:selected /template/ Border#SelectionIndicator">
        <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem:selected /template/ Border#SelectedPipe">
        <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem:selected /template/ Rectangle#SelectionIndicator">
        <Setter Property="IsVisible" Value="False" />
    </Style>
</Styles>
