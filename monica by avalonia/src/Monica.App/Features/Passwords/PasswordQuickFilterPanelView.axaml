<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.Passwords.PasswordQuickFilterPanelView"
             x:DataType="vm:MainWindowViewModel"
             MinWidth="312">
    <Border Padding="12">
        <StackPanel Spacing="10">
            <TextBlock Text="{Binding L.PasswordFilters}" FontSize="14" FontWeight="SemiBold" />
            <UniformGrid Columns="2" Rows="4">
                <ToggleButton Classes="passwordFilterOption" Margin="0,0,6,6" IsChecked="{Binding QuickFilterFavorite}" AutomationProperties.Name="{Binding L.QuickFilterFavorite}">
                    <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="Star" FontSize="15" /><TextBlock Text="{Binding L.QuickFilterFavorite}" /></StackPanel>
                </ToggleButton>
                <ToggleButton Classes="passwordFilterOption" Margin="0,0,0,6" IsChecked="{Binding QuickFilter2Fa}" AutomationProperties.Name="{Binding L.QuickFilter2Fa}">
                    <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="Key" FontSize="15" /><TextBlock Text="{Binding L.QuickFilter2Fa}" /></StackPanel>
                </ToggleButton>
                <ToggleButton Classes="passwordFilterOption" Margin="0,0,6,6" IsChecked="{Binding QuickFilterNotes}" AutomationProperties.Name="{Binding L.QuickFilterNotes}">
                    <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="Note" FontSize="15" /><TextBlock Text="{Binding L.QuickFilterNotes}" /></StackPanel>
                </ToggleButton>
                <ToggleButton Classes="passwordFilterOption" Margin="0,0,0,6" IsChecked="{Binding QuickFilterPasskey}" AutomationProperties.Name="{Binding L.QuickFilterPasskey}">
                    <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="Fingerprint" FontSize="15" /><TextBlock Text="{Binding L.QuickFilterPasskey}" /></StackPanel>
                </ToggleButton>
                <ToggleButton Classes="passwordFilterOption" Margin="0,0,6,6" IsChecked="{Binding QuickFilterBoundNote}" AutomationProperties.Name="{Binding L.QuickFilterBoundNote}">
                    <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="Document" FontSize="15" /><TextBlock Text="{Binding L.QuickFilterBoundNote}" /></StackPanel>
                </ToggleButton>
                <ToggleButton Classes="passwordFilterOption" Margin="0,0,0,6" IsChecked="{Binding QuickFilterUncategorized}" AutomationProperties.Name="{Binding L.QuickFilterUncategorized}">
                    <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="Folder" FontSize="15" /><TextBlock Text="{Binding L.QuickFilterUncategorized}" /></StackPanel>
                </ToggleButton>
                <ToggleButton Classes="passwordFilterOption" Margin="0,0,6,0" IsChecked="{Binding QuickFilterLocalOnly}" AutomationProperties.Name="{Binding L.QuickFilterLocalOnly}">
                    <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="Desktop" FontSize="15" /><TextBlock Text="{Binding L.QuickFilterLocalOnly}" /></StackPanel>
                </ToggleButton>
                <ToggleButton Classes="passwordFilterOption" IsChecked="{Binding QuickFilterAttachments}" AutomationProperties.Name="{Binding L.QuickFilterAttachments}">
                    <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="Attach" FontSize="15" /><TextBlock Text="{Binding L.QuickFilterAttachments}" /></StackPanel>
                </ToggleButton>
            </UniformGrid>
        </StackPanel>
    </Border>
</UserControl>
