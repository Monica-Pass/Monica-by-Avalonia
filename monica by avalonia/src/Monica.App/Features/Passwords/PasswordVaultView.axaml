<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:local="using:Monica.App"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.Passwords.PasswordVaultView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
    <Style Selector="Button.passwordPrimaryCommand">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Foreground" Value="#101010" />
    </Style>
    <Style Selector="Button.passwordCommand">
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="7,5" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.passwordInlineCommand">
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="ToggleButton.passwordFilterChip">
        <Setter Property="MinWidth" Value="34" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="Padding" Value="7,4" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="ToggleButton.passwordFilterChip:checked">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
    </Style>
    <Style Selector="Border.passwordChromeToolbar">
        <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8" />
    </Style>
    <Style Selector="Border.passwordFolderStrip">
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="0,2,0,8" />
    </Style>
    <Style Selector="Border.passwordSidebar">
        <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,0" />
        <Setter Property="Padding" Value="10,8" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="62" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem:selected">
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem:selected /template/ Border#SelectionIndicator">
        <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem:selected /template/ Border#SelectedPipe">
        <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="ListBox.passwordVaultList ListBoxItem:selected /template/ Rectangle#SelectionIndicator">
        <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="ListBox.passwordFolderList ListBoxItem">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="ListBox.passwordFolderList ListBoxItem:selected">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
    </Style>
    <Style Selector="ListBox.passwordFolderBar ListBoxItem">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Margin" Value="0,0,4,0" />
        <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.passwordFolderBar ListBoxItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
    </Style>
    <Style Selector="ListBox.passwordFolderBar ListBoxItem:selected">
        <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    </UserControl.Styles>

                    <Grid RowDefinitions="Auto,Auto,Auto,*">
                        <Border Grid.Row="0" Classes="passwordChromeToolbar" Margin="0,0,0,6">
                            <Grid ColumnDefinitions="320,Auto,*" ColumnSpacing="8">
                                <Grid Width="320" ColumnDefinitions="*,Auto" ColumnSpacing="4">
                                    <TextBox x:Name="PasswordSearchBox"
                                             PlaceholderText="{Binding L.Search}"
                                             Text="{Binding PasswordSearchText}"
                                             Height="34"
                                             VerticalAlignment="Center"
                                             AutomationProperties.Name="{Binding L.Search}" />
                                    <Button x:Name="PasswordSearchClearButton"
                                            Grid.Column="1"
                                            Classes="passwordCommand"
                                            Command="{Binding ClearPasswordSearchCommand}"
                                            IsVisible="{Binding HasPasswordSearchText}"
                                            ToolTip.Tip="{Binding ClearPasswordFiltersText}"
                                            AutomationProperties.Name="{Binding ClearPasswordFiltersText}">
                                        <ic:FluentIcon Icon="Dismiss" FontSize="16" />
                                    </Button>
                                </Grid>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Button Classes="passwordPrimaryCommand" Command="{Binding AddPasswordCommand}" ToolTip.Tip="{Binding L.AddPassword}" AutomationProperties.Name="{Binding L.AddPassword}">
                                        <ic:FluentIcon Icon="Add" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Button>
                                    <Button Classes="passwordCommand" Command="{Binding SelectSectionCommand}" CommandParameter="Generator" ToolTip.Tip="{Binding L.PasswordGenerator}" AutomationProperties.Name="{Binding L.PasswordGenerator}">
                                        <ic:FluentIcon Icon="Key" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Button>
                                    <Button Classes="passwordCommand" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}" AutomationProperties.Name="{Binding L.Refresh}">
                                        <ic:FluentIcon Icon="ArrowSync" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Button>
                                    <Button Classes="passwordCommand" ToolTip.Tip="{Binding PasswordSortButtonTip}" AutomationProperties.Name="{Binding PasswordSortButtonTip}">
                                        <ic:FluentIcon Icon="TextBulletList" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuItem Header="{Binding SortUpdatedText}" Command="{Binding SetPasswordSortCommand}" CommandParameter="updated-desc">
                                                    <MenuItem.Icon>
                                                        <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" IsVisible="{Binding IsSortUpdatedSelected}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{Binding SortTitleText}" Command="{Binding SetPasswordSortCommand}" CommandParameter="title-asc">
                                                    <MenuItem.Icon>
                                                        <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" IsVisible="{Binding IsSortTitleSelected}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{Binding SortWebsiteText}" Command="{Binding SetPasswordSortCommand}" CommandParameter="website-asc">
                                                    <MenuItem.Icon>
                                                        <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" IsVisible="{Binding IsSortWebsiteSelected}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{Binding SortUsernameText}" Command="{Binding SetPasswordSortCommand}" CommandParameter="username-asc">
                                                    <MenuItem.Icon>
                                                        <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" IsVisible="{Binding IsSortUsernameSelected}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{Binding SortCreatedText}" Command="{Binding SetPasswordSortCommand}" CommandParameter="created-desc">
                                                    <MenuItem.Icon>
                                                        <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" IsVisible="{Binding IsSortCreatedSelected}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{Binding SortFavoritesText}" Command="{Binding SetPasswordSortCommand}" CommandParameter="favorites-first">
                                                    <MenuItem.Icon>
                                                        <ic:FluentIcon Icon="CheckmarkCircle" FontSize="16" IsVisible="{Binding IsSortFavoritesSelected}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                    <Button Classes="passwordCommand" ToolTip.Tip="{Binding L.MoreOptions}" AutomationProperties.Name="{Binding L.MoreOptions}">
                                        <ic:FluentIcon Icon="MoreHorizontal" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuItem Header="{Binding L.ImportPasswordCsv}" Command="{Binding ImportPasswordCsvFileCommand}">
                                                    <MenuItem.Icon>
                                                        <ic:FluentIcon Icon="FolderOpen" FontSize="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{Binding L.ExportPasswordCsv}" Command="{Binding SavePasswordCsvExportCommand}">
                                                    <MenuItem.Icon>
                                                        <ic:FluentIcon Icon="ArrowDownload" FontSize="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{Binding L.ExportData}" Command="{Binding SaveMonicaJsonExportCommand}">
                                                    <MenuItem.Icon>
                                                        <ic:FluentIcon Icon="Document" FontSize="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{Binding L.Archive}" Command="{Binding SelectSectionCommand}" CommandParameter="Archive">
                                                    <MenuItem.Icon>
                                                        <ic:FluentIcon Icon="FolderOpen" FontSize="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{Binding L.DeletedPasswords}" Command="{Binding SelectSectionCommand}" CommandParameter="RecycleBin">
                                                    <MenuItem.Icon>
                                                        <ic:FluentIcon Icon="Delete" FontSize="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </StackPanel>

                                <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border IsVisible="{Binding HasPasswordFilters}" Padding="8,4" CornerRadius="6" Background="{DynamicResource LayerFillColorSubtleBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" MaxWidth="220" Margin="0,0,6,4" VerticalAlignment="Center">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                            <ic:FluentIcon Icon="Info" FontSize="14" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding PasswordFilterSummaryText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                    <Button Classes="passwordCommand" Command="{Binding ClearPasswordFiltersCommand}" IsVisible="{Binding HasPasswordFilters}" ToolTip.Tip="{Binding ClearPasswordFiltersText}" AutomationProperties.Name="{Binding ClearPasswordFiltersText}" Margin="0,0,6,4">
                                        <ic:FluentIcon Icon="Dismiss" FontSize="17" />
                                    </Button>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,6,4" IsChecked="{Binding QuickFilterFavorite}" ToolTip.Tip="{Binding L.QuickFilterFavorite}" AutomationProperties.Name="{Binding L.QuickFilterFavorite}">
                                        <ic:FluentIcon Icon="Star" FontSize="15" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,6,4" IsChecked="{Binding QuickFilter2Fa}" ToolTip.Tip="{Binding L.QuickFilter2Fa}" AutomationProperties.Name="{Binding L.QuickFilter2Fa}">
                                        <ic:FluentIcon Icon="Key" FontSize="15" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,6,4" IsChecked="{Binding QuickFilterNotes}" ToolTip.Tip="{Binding L.QuickFilterNotes}" AutomationProperties.Name="{Binding L.QuickFilterNotes}">
                                        <ic:FluentIcon Icon="Note" FontSize="15" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,6,4" IsChecked="{Binding QuickFilterPasskey}" ToolTip.Tip="{Binding L.QuickFilterPasskey}" AutomationProperties.Name="{Binding L.QuickFilterPasskey}">
                                        <ic:FluentIcon Icon="Fingerprint" FontSize="15" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,6,4" IsChecked="{Binding QuickFilterBoundNote}" ToolTip.Tip="{Binding L.QuickFilterBoundNote}" AutomationProperties.Name="{Binding L.QuickFilterBoundNote}">
                                        <ic:FluentIcon Icon="Document" FontSize="15" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,6,4" IsChecked="{Binding QuickFilterUncategorized}" ToolTip.Tip="{Binding L.QuickFilterUncategorized}" AutomationProperties.Name="{Binding L.QuickFilterUncategorized}">
                                        <ic:FluentIcon Icon="Folder" FontSize="15" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,6,4" IsChecked="{Binding QuickFilterLocalOnly}" ToolTip.Tip="{Binding L.QuickFilterLocalOnly}" AutomationProperties.Name="{Binding L.QuickFilterLocalOnly}">
                                        <ic:FluentIcon Icon="Desktop" FontSize="15" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                    <ToggleButton Classes="passwordFilterChip" Margin="0,0,6,4" IsChecked="{Binding QuickFilterAttachments}" ToolTip.Tip="{Binding L.QuickFilterAttachments}" AutomationProperties.Name="{Binding L.QuickFilterAttachments}">
                                        <ic:FluentIcon Icon="Attach" FontSize="15" HorizontalAlignment="Center" />
                                    </ToggleButton>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                IsVisible="{Binding HasSelectedPasswords}"
                                BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="10,8"
                                Background="{DynamicResource AccentFillColorTertiaryBrush}"
                                Margin="0,0,0,10">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <ic:FluentIcon Icon="CheckboxChecked" FontSize="18" />
                                    <TextBlock Text="{Binding SelectedPasswordCountText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>
                                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding FavoriteSelectedPasswordsCommand}" ToolTip.Tip="{Binding L.BatchFavorite}" AutomationProperties.Name="{Binding L.BatchFavorite}">
                                        <ic:FluentIcon Icon="Star" FontSize="18" />
                                    </Button>
                                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding MoveSelectedPasswordsToCategoryCommand}" ToolTip.Tip="{Binding L.MoveToFolder}" AutomationProperties.Name="{Binding L.MoveToFolder}">
                                        <ic:FluentIcon Icon="Folder" FontSize="18" />
                                    </Button>
                                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding StackSelectedPasswordsCommand}" IsEnabled="{Binding CanStackSelectedPasswords}" ToolTip.Tip="{Binding L.StackSelectedPasswords}" AutomationProperties.Name="{Binding L.StackSelectedPasswords}">
                                        <ic:FluentIcon Icon="Library" FontSize="18" />
                                    </Button>
                                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding ArchiveSelectedPasswordsCommand}" ToolTip.Tip="{Binding L.BatchArchive}" AutomationProperties.Name="{Binding L.BatchArchive}">
                                        <ic:FluentIcon Icon="FolderOpen" FontSize="18" />
                                    </Button>
                                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding DeleteSelectedPasswordsCommand}" ToolTip.Tip="{Binding L.BatchDelete}" AutomationProperties.Name="{Binding L.BatchDelete}">
                                        <ic:FluentIcon Icon="Delete" FontSize="18" />
                                    </Button>
                                    <Button Classes="passwordCommand" Margin="0,0,0,6" Command="{Binding ClearPasswordSelectionCommand}" ToolTip.Tip="{Binding L.Cancel}" AutomationProperties.Name="{Binding L.Cancel}">
                                        <ic:FluentIcon Icon="Dismiss" FontSize="18" />
                                    </Button>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Classes="passwordFolderStrip" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="*,150,Auto,Auto,Auto" ColumnSpacing="8" MinHeight="34">
                                <ScrollViewer
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <ListBox Classes="passwordFolderList passwordFolderBar"
                                                 ItemsSource="{Binding SystemPasswordFolderFilters}"
                                                 SelectedItem="{Binding SelectedPasswordFolderFilter}"
                                                 SelectionMode="Single"
                                                 Padding="0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                 Background="Transparent">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:PasswordFolderFilterChoice">
                                                    <Border Padding="9,6" CornerRadius="6" Background="Transparent" HorizontalAlignment="Stretch">
                                                        <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="7" MinHeight="28">
                                                            <ic:FluentIcon Icon="Folder" FontSize="15" VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="1" Text="{Binding FolderDisplayName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTip.Tip="{Binding Name}" />
                                                            <Border Grid.Column="2" Padding="7,2" CornerRadius="9" Background="{DynamicResource LayerFillColorSubtleBrush}" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Count}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <ListBox Classes="passwordFolderList passwordFolderBar"
                                                 ItemsSource="{Binding RegularPasswordFolderFilters}"
                                                 SelectedItem="{Binding SelectedPasswordFolderFilter}"
                                                 SelectionMode="Single"
                                                 Padding="0"
                                                 IsVisible="{Binding HasRegularPasswordFolderFilters}"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                 Background="Transparent">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate x:DataType="vm:PasswordFolderFilterChoice">
                                                    <Border Padding="7,6" CornerRadius="6" Background="Transparent" HorizontalAlignment="Stretch">
                                                        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6" Margin="{Binding Indent}" MinHeight="28">
                                                            <Button Classes="passwordInlineCommand"
                                                                    Command="{Binding #Root.DataContext.TogglePasswordFolderExpansionCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    IsEnabled="{Binding HasChildren}"
                                                                    Opacity="{Binding HasChildren, Converter={x:Static local:BoolConverters.ToOpacity}}"
                                                                    Width="24"
                                                                    Height="24"
                                                                    Padding="0"
                                                                    ToolTip.Tip="{Binding Name}">
                                                                <Panel>
                                                                    <ic:FluentIcon Icon="ChevronDown" FontSize="12" IsVisible="{Binding IsExpanded}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    <ic:FluentIcon Icon="ChevronRight" FontSize="12" IsVisible="{Binding IsExpanded, Converter={x:Static local:BoolConverters.Not}}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Panel>
                                                            </Button>
                                                            <Panel Grid.Column="1" Width="17" Height="17" VerticalAlignment="Center">
                                                                <ic:FluentIcon Icon="FolderOpen" FontSize="14" IsVisible="{Binding IsExpanded}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                <ic:FluentIcon Icon="Folder" FontSize="14" IsVisible="{Binding IsExpanded, Converter={x:Static local:BoolConverters.Not}}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Panel>
                                                            <TextBlock Grid.Column="2" Text="{Binding FolderDisplayName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTip.Tip="{Binding Name}" />
                                                            <Border Grid.Column="3" Padding="7,2" CornerRadius="9" Background="{DynamicResource LayerFillColorSubtleBrush}" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Count}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </ScrollViewer>

                                <TextBox Grid.Column="1" Text="{Binding NewFolderName}" PlaceholderText="{Binding L.NewFolder}" Height="32" VerticalAlignment="Center" AutomationProperties.Name="{Binding L.NewFolder}" />
                                <Button Grid.Column="2" Command="{Binding CreatePasswordFolderCommand}" ToolTip.Tip="{Binding L.CreateFolder}" AutomationProperties.Name="{Binding L.CreateFolder}" Width="34" Height="32" Padding="0" VerticalAlignment="Center">
                                    <ic:FluentIcon Icon="FolderAdd" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Button>
                                <Button Grid.Column="3" Command="{Binding RenameSelectedPasswordFolderCommand}" IsEnabled="{Binding CanManageSelectedPasswordFolder}" ToolTip.Tip="{Binding L.RenameFolder}" AutomationProperties.Name="{Binding L.RenameFolder}" Width="32" Height="32" Padding="0" VerticalAlignment="Center">
                                    <ic:FluentIcon Icon="Edit" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Button>
                                <Button Grid.Column="4" Command="{Binding DeleteSelectedPasswordFolderCommand}" IsEnabled="{Binding CanManageSelectedPasswordFolder}" ToolTip.Tip="{Binding L.DeleteFolder}" AutomationProperties.Name="{Binding L.DeleteFolder}" Width="32" Height="32" Padding="0" VerticalAlignment="Center">
                                    <ic:FluentIcon Icon="Delete" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Button>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3" ColumnDefinitions="300,*" ColumnSpacing="0" MinWidth="0" ClipToBounds="True">
                            <Border Classes="passwordSidebar">
                                <Grid RowDefinitions="Auto,*" RowSpacing="8">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" MinHeight="32">
                                        <StackPanel>
                                            <TextBlock Text="{Binding L.Passwords}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Text="{Binding PasswordCountText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <CheckBox x:Name="SelectAllVisiblePasswordsCheckBox"
                                                  Grid.Column="1"
                                                  IsChecked="{Binding AreAllFilteredPasswordsSelected}"
                                                  ToolTip.Tip="{Binding SelectAllVisiblePasswordsText}"
                                                  AutomationProperties.Name="{Binding SelectAllVisiblePasswordsText}"
                                                  VerticalAlignment="Center" />
                                    </Grid>

                                    <Grid Grid.Row="1">
                                    <ListBox x:Name="PasswordListBox"
                                             Classes="passwordVaultList"
                                             ItemsSource="{Binding FilteredPasswordRows}"
                                             SelectedItem="{Binding SelectedPasswordListRow}"
                                             SelectionMode="Single"
                                             Padding="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             Background="Transparent">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel Orientation="Vertical" CacheLength="2" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:PasswordListRow">
                                                <Border Margin="{Binding RowMargin}" Padding="8,6" CornerRadius="7" Background="Transparent" HorizontalAlignment="Stretch" MinHeight="{Binding RowMinHeight}">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="{Binding #Root.DataContext.SelectPasswordItemsText}"
                                                                      Command="{Binding #Root.DataContext.TogglePasswordRowSelectionCommand}"
                                                                      CommandParameter="{Binding}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="CheckboxChecked" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{Binding #Root.DataContext.L.CopyUsername}"
                                                                      Command="{Binding #Root.DataContext.CopyUsernameCommand}"
                                                                      CommandParameter="{Binding Entry}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="Copy" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="{Binding #Root.DataContext.L.CopyPassword}"
                                                                      Command="{Binding #Root.DataContext.CopyPasswordCommand}"
                                                                      CommandParameter="{Binding Entry}">
                                                                <MenuItem.Icon>
                                                                    <ic:FluentIcon Icon="Key" FontSize="16" />
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Grid>
                                                        <Border Width="2"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Stretch"
                                                                Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                                Opacity="0.85"
                                                                IsVisible="{Binding IsStackChild}"
                                                                Margin="{Binding StackLineMargin}" />
                                                        <Grid RowDefinitions="Auto,Auto">
                                                            <Grid IsVisible="{Binding IsStackHeader}" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                                                                <Button Classes="passwordInlineCommand"
                                                                        Command="{Binding #Root.DataContext.TogglePasswordStackRowCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        ToolTip.Tip="{Binding #Root.DataContext.L.StackSelectedPasswords}"
                                                                        AutomationProperties.Name="{Binding #Root.DataContext.L.StackSelectedPasswords}">
                                                                    <Grid Width="16" Height="16">
                                                                        <ic:FluentIcon Icon="ChevronRight" FontSize="15" IsVisible="{Binding IsCollapsed}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        <ic:FluentIcon Icon="ChevronDown" FontSize="15" IsVisible="{Binding IsExpanded}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Grid>
                                                                </Button>
                                                                <Border Grid.Column="1" Width="34" Height="34" CornerRadius="17" Background="{DynamicResource AccentFillColorDefaultBrush}">
                                                                    <TextBlock Text="{Binding Entry.AvatarText}" Foreground="White" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                                <Grid Grid.Column="2" RowDefinitions="Auto,Auto" VerticalAlignment="Center">
                                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                        <TextBlock Text="{Binding Entry.Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                                            <Border Padding="6,1" CornerRadius="8" Background="{DynamicResource AccentFillColorTertiaryBrush}">
                                                                                <TextBlock Text="{Binding StackCountText}" FontSize="11" FontWeight="SemiBold" />
                                                                            </Border>
                                                                            <ic:FluentIcon Icon="Star" FontSize="13" IsVisible="{Binding HasGroupFavorite}" />
                                                                            <ic:FluentIcon Icon="Key" FontSize="13" IsVisible="{Binding HasGroupAuthenticator}" />
                                                                            <ic:FluentIcon Icon="Attach" FontSize="13" IsVisible="{Binding HasGroupAttachments}" />
                                                                        </StackPanel>
                                                                    </Grid>
                                                                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                        <TextBlock Text="{Binding StackSubtitle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding Entry.Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" MaxWidth="120" />
                                                                    </Grid>
                                                                </Grid>
                                                                <CheckBox Grid.Column="3"
                                                                          Classes="passwordRowSelection"
                                                                          IsChecked="{Binding IsGroupSelected}"
                                                                          AutomationProperties.Name="{Binding #Root.DataContext.SelectPasswordItemsText}"
                                                                          VerticalAlignment="Center" />
                                                            </Grid>
                                                            <Grid IsVisible="{Binding IsPasswordEntryRow}" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                                                <Border Width="34" Height="34" CornerRadius="17" Background="{DynamicResource AccentFillColorDefaultBrush}">
                                                                    <TextBlock Text="{Binding Entry.AvatarText}" Foreground="White" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                                <Grid Grid.Column="1" RowDefinitions="Auto,Auto" VerticalAlignment="Center">
                                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                        <TextBlock Text="{Binding Entry.Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                                            <ic:FluentIcon Icon="Star" FontSize="13" IsVisible="{Binding Entry.IsFavorite}" />
                                                                            <ic:FluentIcon Icon="Key" FontSize="13" IsVisible="{Binding Entry.HasAuthenticator}" />
                                                                            <ic:FluentIcon Icon="Attach" FontSize="13" IsVisible="{Binding Entry.HasAttachments}" />
                                                                        </StackPanel>
                                                                    </Grid>
                                                                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                                        <TextBlock Text="{Binding Entry.Username}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding Entry.Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" MaxWidth="120" />
                                                                    </Grid>
                                                                </Grid>
                                                                <CheckBox Grid.Column="2"
                                                                          Classes="passwordRowSelection"
                                                                          IsChecked="{Binding Entry.IsSelected}"
                                                                          AutomationProperties.Name="{Binding #Root.DataContext.SelectPasswordItemsText}"
                                                                          VerticalAlignment="Center" />
                                                            </Grid>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <StackPanel x:Name="PasswordListEmptyState"
                                                IsVisible="{Binding !HasFilteredPasswordRows}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Spacing="10"
                                                Margin="20"
                                                MaxWidth="240">
                                        <ic:FluentIcon Icon="Key"
                                                       FontSize="34"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding PasswordEmptyStateText}"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center" />
                                        <Button x:Name="EmptyStateAddPasswordButton"
                                                Classes="passwordPrimaryCommand"
                                                Command="{Binding AddPasswordCommand}"
                                                IsVisible="{Binding ShowAddPasswordInEmptyState}"
                                                AutomationProperties.Name="{Binding L.AddPassword}"
                                                HorizontalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Add" FontSize="17" />
                                                <TextBlock Text="{Binding L.AddPassword}" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="EmptyStateClearFiltersButton"
                                                Classes="passwordCommand"
                                                Command="{Binding ClearPasswordFiltersCommand}"
                                                IsVisible="{Binding ShowClearPasswordFiltersInEmptyState}"
                                                AutomationProperties.Name="{Binding ClearPasswordFiltersText}"
                                                HorizontalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ic:FluentIcon Icon="Dismiss" FontSize="17" />
                                                <TextBlock Text="{Binding ClearPasswordFiltersText}" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    </Grid>

                                </Grid>
                            </Border>

                            <Border x:Name="PasswordDetailRegion" Grid.Column="1" Focusable="True" CornerRadius="8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundBrush}" Margin="12,0,0,0" MinWidth="0" ClipToBounds="True">
                                <Grid RowDefinitions="Auto,*">
                                    <Border IsVisible="{Binding HasSelectedPassword}"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="16,14">
                                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                            <Border Width="46" Height="46" CornerRadius="23" Background="{DynamicResource AccentFillColorDefaultBrush}" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SelectedPassword.AvatarText}" Foreground="White" FontWeight="SemiBold" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <Grid Grid.Column="1" RowDefinitions="Auto,Auto" RowSpacing="2" VerticalAlignment="Center" MinWidth="0">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" MinWidth="0">
                                                    <TextBlock Text="{Binding SelectedPasswordTitle}" FontSize="20" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MinWidth="0" MaxWidth="300" HorizontalAlignment="Left" ToolTip.Tip="{Binding SelectedPasswordTitle}" />
                                                    <Border Grid.Column="1" Padding="8,2" CornerRadius="10" Background="{DynamicResource LayerFillColorSubtleBrush}" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding SelectedPasswordSourceText}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Grid.Row="1" Text="{Binding SelectedPasswordSubtitle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" MinWidth="0" MaxWidth="300" HorizontalAlignment="Left" ToolTip.Tip="{Binding SelectedPasswordSubtitle}" />
                                            </Grid>
                                            <WrapPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,0" Orientation="Horizontal">
                                                <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding CopyUsernameCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.CopyUsername}" AutomationProperties.Name="{Binding L.CopyUsername}">
                                                    <ic:FluentIcon Icon="Copy" FontSize="18" />
                                                </Button>
                                                <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding CopyPasswordCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.CopyPassword}" AutomationProperties.Name="{Binding L.CopyPassword}">
                                                    <ic:FluentIcon Icon="Key" FontSize="18" />
                                                </Button>
                                                <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding CopyWebsiteCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.CopyWebsite}" AutomationProperties.Name="{Binding L.CopyWebsite}">
                                                    <ic:FluentIcon Icon="Link" FontSize="18" />
                                                </Button>
                                                <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding ToggleFavoriteCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.Favorite}" AutomationProperties.Name="{Binding L.Favorite}">
                                                    <ic:FluentIcon Icon="Star" FontSize="18" />
                                                </Button>
                                                <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding EditPasswordCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.EditPassword}" AutomationProperties.Name="{Binding L.EditPassword}">
                                                    <ic:FluentIcon Icon="Edit" FontSize="18" />
                                                </Button>
                                                <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding ArchivePasswordCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.ArchivePassword}" AutomationProperties.Name="{Binding L.ArchivePassword}">
                                                    <ic:FluentIcon Icon="FolderOpen" FontSize="18" />
                                                </Button>
                                                <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding DeletePasswordCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.MoveToRecycleBin}" AutomationProperties.Name="{Binding L.MoveToRecycleBin}">
                                                    <ic:FluentIcon Icon="Delete" FontSize="18" />
                                                </Button>
                                            </WrapPanel>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="1" ClipToBounds="True">
                                        <StackPanel Classes="workspaceEmptyState"
                                                    IsVisible="{Binding HasNoSelectedPassword}"
                                                    Spacing="10"
                                                    Width="260"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Margin="24">
                                            <ic:FluentIcon Icon="Info" FontSize="32" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding L.PasswordDetails}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding PasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel IsVisible="{Binding HasSelectedPasswordLoadingState}"
                                                    Panel.ZIndex="2"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Spacing="12"
                                                    Width="260">
                                            <ProgressBar IsIndeterminate="True" Height="4" />
                                            <TextBlock Text="{Binding L.LoadingPasswordDetails}" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                                        </StackPanel>
                                        <local:PasswordDetailDialog Margin="16" DataContext="{Binding SelectedPasswordDetails}" ShowHeader="False" IsVisible="{Binding #Root.DataContext.HasCurrentSelectedPasswordDetails}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
</UserControl>
