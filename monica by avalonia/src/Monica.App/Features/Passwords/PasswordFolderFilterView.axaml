<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:local="using:Monica.App"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.Passwords.PasswordFolderFilterView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="Auto,Auto">
        <Border IsVisible="{Binding HasSelectedPasswords}"
                BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="7"
                Padding="10,8"
                Background="{DynamicResource AccentFillColorTertiaryBrush}"
                Margin="0,0,0,10">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ic:FluentIcon Icon="CheckboxChecked" FontSize="18" />
                    <TextBlock Text="{Binding SelectedPasswordCountText}" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding FavoriteSelectedPasswordsCommand}" ToolTip.Tip="{Binding L.BatchFavorite}" AutomationProperties.Name="{Binding L.BatchFavorite}"><ic:FluentIcon Icon="Star" FontSize="18" /></Button>
                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding MoveSelectedPasswordsToCategoryCommand}" ToolTip.Tip="{Binding L.MoveToFolder}" AutomationProperties.Name="{Binding L.MoveToFolder}"><ic:FluentIcon Icon="Folder" FontSize="18" /></Button>
                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding StackSelectedPasswordsCommand}" IsEnabled="{Binding CanStackSelectedPasswords}" ToolTip.Tip="{Binding L.StackSelectedPasswords}" AutomationProperties.Name="{Binding L.StackSelectedPasswords}"><ic:FluentIcon Icon="Library" FontSize="18" /></Button>
                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding ArchiveSelectedPasswordsCommand}" ToolTip.Tip="{Binding L.BatchArchive}" AutomationProperties.Name="{Binding L.BatchArchive}"><ic:FluentIcon Icon="FolderOpen" FontSize="18" /></Button>
                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding DeleteSelectedPasswordsCommand}" ToolTip.Tip="{Binding L.BatchDelete}" AutomationProperties.Name="{Binding L.BatchDelete}"><ic:FluentIcon Icon="Delete" FontSize="18" /></Button>
                    <Button Classes="passwordCommand" Margin="0,0,0,6" Command="{Binding ClearPasswordSelectionCommand}" ToolTip.Tip="{Binding L.Cancel}" AutomationProperties.Name="{Binding L.Cancel}"><ic:FluentIcon Icon="Dismiss" FontSize="18" /></Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="passwordFolderStrip" Margin="0,0,0,8">
            <Grid ColumnDefinitions="*,150,Auto,Auto,Auto" ColumnSpacing="8" MinHeight="34">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ListBox Classes="passwordFolderList passwordFolderBar"
                                 ItemsSource="{Binding SystemPasswordFolderFilters}"
                                 SelectedItem="{Binding SelectedPasswordFolderFilter}"
                                 SelectionMode="Single"
                                 Padding="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 Background="Transparent">
                            <ListBox.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:PasswordFolderFilterChoice">
                                    <Border Padding="9,6" CornerRadius="6" Background="Transparent" HorizontalAlignment="Stretch">
                                        <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="7" MinHeight="28">
                                            <ic:FluentIcon Icon="Folder" FontSize="15" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding FolderDisplayName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTip.Tip="{Binding Name}" />
                                            <Border Grid.Column="2" Padding="7,2" CornerRadius="9" Background="{DynamicResource LayerFillColorSubtleBrush}" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Count}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <ListBox Classes="passwordFolderList passwordFolderBar"
                                 ItemsSource="{Binding RegularPasswordFolderFilters}"
                                 SelectedItem="{Binding SelectedPasswordFolderFilter}"
                                 SelectionMode="Single"
                                 Padding="0"
                                 IsVisible="{Binding HasRegularPasswordFolderFilters}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 Background="Transparent">
                            <ListBox.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:PasswordFolderFilterChoice">
                                    <Border Padding="7,6" CornerRadius="6" Background="Transparent" HorizontalAlignment="Stretch">
                                        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="6" Margin="{Binding Indent}" MinHeight="28">
                                            <Button Classes="passwordInlineCommand"
                                                    Command="{Binding #Root.DataContext.TogglePasswordFolderExpansionCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsEnabled="{Binding HasChildren}"
                                                    Opacity="{Binding HasChildren, Converter={x:Static local:BoolConverters.ToOpacity}}"
                                                    Width="24"
                                                    Height="24"
                                                    Padding="0"
                                                    ToolTip.Tip="{Binding Name}">
                                                <Panel>
                                                    <ic:FluentIcon Icon="ChevronDown" FontSize="12" IsVisible="{Binding IsExpanded}" />
                                                    <ic:FluentIcon Icon="ChevronRight" FontSize="12" IsVisible="{Binding IsExpanded, Converter={x:Static local:BoolConverters.Not}}" />
                                                </Panel>
                                            </Button>
                                            <Panel Grid.Column="1" Width="17" Height="17" VerticalAlignment="Center">
                                                <ic:FluentIcon Icon="FolderOpen" FontSize="14" IsVisible="{Binding IsExpanded}" />
                                                <ic:FluentIcon Icon="Folder" FontSize="14" IsVisible="{Binding IsExpanded, Converter={x:Static local:BoolConverters.Not}}" />
                                            </Panel>
                                            <TextBlock Grid.Column="2" Text="{Binding FolderDisplayName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" ToolTip.Tip="{Binding Name}" />
                                            <Border Grid.Column="3" Padding="7,2" CornerRadius="9" Background="{DynamicResource LayerFillColorSubtleBrush}" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Count}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
                <TextBox Grid.Column="1" Text="{Binding NewFolderName}" PlaceholderText="{Binding L.NewFolder}" Height="32" VerticalAlignment="Center" AutomationProperties.Name="{Binding L.NewFolder}" />
                <Button Grid.Column="2" Command="{Binding CreatePasswordFolderCommand}" ToolTip.Tip="{Binding L.CreateFolder}" AutomationProperties.Name="{Binding L.CreateFolder}" Width="34" Height="32" Padding="0"><ic:FluentIcon Icon="FolderAdd" FontSize="15" /></Button>
                <Button Grid.Column="3" Command="{Binding RenameSelectedPasswordFolderCommand}" IsEnabled="{Binding CanManageSelectedPasswordFolder}" ToolTip.Tip="{Binding L.RenameFolder}" AutomationProperties.Name="{Binding L.RenameFolder}" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="Edit" FontSize="14" /></Button>
                <Button Grid.Column="4" Command="{Binding DeleteSelectedPasswordFolderCommand}" IsEnabled="{Binding CanManageSelectedPasswordFolder}" ToolTip.Tip="{Binding L.DeleteFolder}" AutomationProperties.Name="{Binding L.DeleteFolder}" Width="32" Height="32" Padding="0"><ic:FluentIcon Icon="Delete" FontSize="14" /></Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
