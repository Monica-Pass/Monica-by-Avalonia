<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.Passwords.PasswordListPaneView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="Auto,*" RowSpacing="8">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" MinHeight="32">
            <StackPanel>
                <TextBlock Text="{Binding L.Passwords}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="{Binding PasswordListStatusText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
            <CheckBox x:Name="SelectAllVisiblePasswordsCheckBox"
                      Grid.Column="1"
                      IsChecked="{Binding AreAllFilteredPasswordsSelected}"
                      ToolTip.Tip="{Binding SelectAllVisiblePasswordsText}"
                      AutomationProperties.Name="{Binding SelectAllVisiblePasswordsText}"
                      VerticalAlignment="Center" />
        </Grid>

        <Grid Grid.Row="1">
            <ListBox x:Name="PasswordListBox"
                     Classes="passwordVaultList"
                     ItemsSource="{Binding FilteredPasswordRows}"
                     SelectedItem="{Binding SelectedPasswordListRow}"
                     SelectionMode="Single"
                     Padding="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Background="Transparent">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Vertical" CacheLength="2" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:PasswordListRow">
                        <Border Margin="{Binding RowMargin}" Padding="8,6" CornerRadius="7" Background="Transparent" HorizontalAlignment="Stretch" MinHeight="{Binding RowMinHeight}">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{Binding #Root.DataContext.SelectPasswordItemsText}" Command="{Binding #Root.DataContext.TogglePasswordRowSelectionCommand}" CommandParameter="{Binding}">
                                        <MenuItem.Icon><ic:FluentIcon Icon="CheckboxChecked" FontSize="16" /></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{Binding #Root.DataContext.L.EditPassword}" InputGesture="F2" Command="{Binding #Root.DataContext.EditPasswordCommand}" CommandParameter="{Binding Entry}">
                                        <MenuItem.Icon><ic:FluentIcon Icon="Edit" FontSize="16" /></MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="{Binding #Root.DataContext.L.CopyUsername}" InputGesture="Ctrl+C" Command="{Binding #Root.DataContext.CopyUsernameCommand}" CommandParameter="{Binding Entry}">
                                        <MenuItem.Icon><ic:FluentIcon Icon="Copy" FontSize="16" /></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{Binding #Root.DataContext.L.CopyPassword}" InputGesture="Ctrl+Shift+C" Command="{Binding #Root.DataContext.CopyPasswordCommand}" CommandParameter="{Binding Entry}">
                                        <MenuItem.Icon><ic:FluentIcon Icon="Key" FontSize="16" /></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{Binding #Root.DataContext.L.CopyWebsite}" Command="{Binding #Root.DataContext.CopyWebsiteCommand}" CommandParameter="{Binding Entry}">
                                        <MenuItem.Icon><ic:FluentIcon Icon="Link" FontSize="16" /></MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="{Binding #Root.DataContext.L.Favorite}" Command="{Binding #Root.DataContext.ToggleFavoriteCommand}" CommandParameter="{Binding Entry}">
                                        <MenuItem.Icon><ic:FluentIcon Icon="Star" FontSize="16" /></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{Binding #Root.DataContext.L.ArchivePassword}" Command="{Binding #Root.DataContext.ArchivePasswordCommand}" CommandParameter="{Binding Entry}">
                                        <MenuItem.Icon><ic:FluentIcon Icon="FolderOpen" FontSize="16" /></MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="{Binding #Root.DataContext.L.MoveToRecycleBin}" Command="{Binding #Root.DataContext.DeletePasswordCommand}" CommandParameter="{Binding Entry}">
                                        <MenuItem.Icon><ic:FluentIcon Icon="Delete" FontSize="16" /></MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Border Width="2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        Opacity="0.85"
                                        IsVisible="{Binding IsStackChild}"
                                        Margin="{Binding StackLineMargin}" />
                                <Grid RowDefinitions="Auto,Auto">
                                    <Grid IsVisible="{Binding IsStackHeader}" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                                        <Button Classes="passwordInlineCommand"
                                                Command="{Binding #Root.DataContext.TogglePasswordStackRowCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{Binding #Root.DataContext.L.StackSelectedPasswords}"
                                                AutomationProperties.Name="{Binding #Root.DataContext.L.StackSelectedPasswords}">
                                            <Grid Width="16" Height="16">
                                                <ic:FluentIcon Icon="ChevronRight" FontSize="15" IsVisible="{Binding IsCollapsed}" />
                                                <ic:FluentIcon Icon="ChevronDown" FontSize="15" IsVisible="{Binding IsExpanded}" />
                                            </Grid>
                                        </Button>
                                        <Border Grid.Column="1" Width="34" Height="34" CornerRadius="17" Background="{DynamicResource AccentFillColorDefaultBrush}">
                                            <TextBlock Text="{Binding Entry.AvatarText}" Foreground="White" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Grid Grid.Column="2" RowDefinitions="Auto,Auto" VerticalAlignment="Center">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBlock Text="{Binding Entry.Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                    <Border Padding="6,1" CornerRadius="8" Background="{DynamicResource AccentFillColorTertiaryBrush}"><TextBlock Text="{Binding StackCountText}" FontSize="11" FontWeight="SemiBold" /></Border>
                                                    <ic:FluentIcon Icon="Star" FontSize="13" IsVisible="{Binding HasGroupFavorite}" />
                                                    <ic:FluentIcon Icon="Key" FontSize="13" IsVisible="{Binding HasGroupAuthenticator}" />
                                                    <ic:FluentIcon Icon="Attach" FontSize="13" IsVisible="{Binding HasGroupAttachments}" />
                                                </StackPanel>
                                            </Grid>
                                            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBlock Text="{Binding StackSubtitle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                <TextBlock Grid.Column="1" Text="{Binding Entry.Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" MaxWidth="120" />
                                            </Grid>
                                        </Grid>
                                        <CheckBox Grid.Column="3" Classes="passwordRowSelection" IsChecked="{Binding IsGroupSelected}" AutomationProperties.Name="{Binding #Root.DataContext.SelectPasswordItemsText}" VerticalAlignment="Center" />
                                    </Grid>
                                    <Grid IsVisible="{Binding IsPasswordEntryRow}" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                        <Border Width="34" Height="34" CornerRadius="17" Background="{DynamicResource AccentFillColorDefaultBrush}">
                                            <TextBlock Text="{Binding Entry.AvatarText}" Foreground="White" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Grid Grid.Column="1" RowDefinitions="Auto,Auto" VerticalAlignment="Center">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBlock Text="{Binding Entry.Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                                    <ic:FluentIcon Icon="Star" FontSize="13" IsVisible="{Binding Entry.IsFavorite}" />
                                                    <ic:FluentIcon Icon="Key" FontSize="13" IsVisible="{Binding Entry.HasAuthenticator}" />
                                                    <ic:FluentIcon Icon="Attach" FontSize="13" IsVisible="{Binding Entry.HasAttachments}" />
                                                </StackPanel>
                                            </Grid>
                                            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBlock Text="{Binding Entry.Username}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" />
                                                <TextBlock Grid.Column="1" Text="{Binding Entry.Website}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" FontSize="12" MaxWidth="120" />
                                            </Grid>
                                        </Grid>
                                        <CheckBox Grid.Column="2" Classes="passwordRowSelection" IsChecked="{Binding Entry.IsSelected}" AutomationProperties.Name="{Binding #Root.DataContext.SelectPasswordItemsText}" VerticalAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel x:Name="PasswordListEmptyState"
                        IsVisible="{Binding !HasFilteredPasswordRows}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Margin="20"
                        MaxWidth="240">
                <ic:FluentIcon Icon="Key" FontSize="34" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding PasswordEmptyStateText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" />
                <Button x:Name="EmptyStateAddPasswordButton" Classes="passwordPrimaryCommand" Command="{Binding AddPasswordCommand}" IsVisible="{Binding ShowAddPasswordInEmptyState}" AutomationProperties.Name="{Binding L.AddPassword}" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="Add" FontSize="17" /><TextBlock Text="{Binding L.AddPassword}" /></StackPanel>
                </Button>
                <Button x:Name="EmptyStateClearFiltersButton" Classes="passwordCommand" Command="{Binding ClearPasswordFiltersCommand}" IsVisible="{Binding ShowClearPasswordFiltersInEmptyState}" AutomationProperties.Name="{Binding ClearPasswordFiltersText}" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="Dismiss" FontSize="17" /><TextBlock Text="{Binding ClearPasswordFiltersText}" /></StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
