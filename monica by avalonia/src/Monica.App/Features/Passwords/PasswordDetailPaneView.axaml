<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="using:Monica.App"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.Features.Passwords.PasswordDetailPaneView"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="Auto,*">
        <Border IsVisible="{Binding HasSelectedPassword}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,14">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="12">
                <Button x:Name="BackToPasswordListButton"
                        Grid.Column="0"
                        Classes="passwordCommand"
                        IsVisible="False"
                        Command="{Binding CloseSelectedPasswordDetailsCommand}"
                        ToolTip.Tip="{Binding BackToPasswordListText}"
                        AutomationProperties.Name="{Binding BackToPasswordListText}"
                        VerticalAlignment="Center">
                    <ic:FluentIcon Icon="ArrowLeft" FontSize="18" />
                </Button>
                <Border Grid.Column="1" Width="46" Height="46" CornerRadius="23" Background="{DynamicResource AccentFillColorDefaultBrush}" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedPassword.AvatarText}" Foreground="White" FontWeight="SemiBold" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Grid Grid.Column="2" RowDefinitions="Auto,Auto" RowSpacing="2" VerticalAlignment="Center" MinWidth="0">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" MinWidth="0">
                        <TextBlock Text="{Binding SelectedPasswordTitle}" FontSize="20" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MinWidth="0" MaxWidth="300" HorizontalAlignment="Left" ToolTip.Tip="{Binding SelectedPasswordTitle}" />
                        <Border Grid.Column="1" Padding="8,2" CornerRadius="10" Background="{DynamicResource LayerFillColorSubtleBrush}" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedPasswordSourceText}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Border>
                    </Grid>
                    <TextBlock Grid.Row="1" Text="{Binding SelectedPasswordSubtitle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" MinWidth="0" MaxWidth="300" HorizontalAlignment="Left" ToolTip.Tip="{Binding SelectedPasswordSubtitle}" />
                </Grid>
                <WrapPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0" Orientation="Horizontal">
                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding CopyUsernameCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.CopyUsername}" AutomationProperties.Name="{Binding L.CopyUsername}"><ic:FluentIcon Icon="Copy" FontSize="18" /></Button>
                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding CopyPasswordCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.CopyPassword}" AutomationProperties.Name="{Binding L.CopyPassword}"><ic:FluentIcon Icon="Key" FontSize="18" /></Button>
                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding CopyWebsiteCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.CopyWebsite}" AutomationProperties.Name="{Binding L.CopyWebsite}"><ic:FluentIcon Icon="Link" FontSize="18" /></Button>
                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding ToggleFavoriteCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.Favorite}" AutomationProperties.Name="{Binding L.Favorite}"><ic:FluentIcon Icon="Star" FontSize="18" /></Button>
                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding EditPasswordCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.EditPassword}" AutomationProperties.Name="{Binding L.EditPassword}"><ic:FluentIcon Icon="Edit" FontSize="18" /></Button>
                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding ArchivePasswordCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.ArchivePassword}" AutomationProperties.Name="{Binding L.ArchivePassword}"><ic:FluentIcon Icon="FolderOpen" FontSize="18" /></Button>
                    <Button Classes="passwordCommand" Margin="0,0,6,6" Command="{Binding DeletePasswordCommand}" CommandParameter="{Binding SelectedPassword}" ToolTip.Tip="{Binding L.MoveToRecycleBin}" AutomationProperties.Name="{Binding L.MoveToRecycleBin}"><ic:FluentIcon Icon="Delete" FontSize="18" /></Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ClipToBounds="True">
            <StackPanel Classes="workspaceEmptyState"
                        IsVisible="{Binding HasNoSelectedPassword}"
                        Spacing="10"
                        Width="260"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="24">
                <ic:FluentIcon Icon="Info" FontSize="32" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding L.PasswordDetails}" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding PasswordCountText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel x:Name="PasswordDetailLoadingState"
                        IsVisible="{Binding HasSelectedPasswordLoadingState}"
                        Panel.ZIndex="2"
                        AutomationProperties.Name="{Binding L.LoadingPasswordDetails}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12"
                        Width="260">
                <ProgressBar IsIndeterminate="True" Height="4" />
                <TextBlock Text="{Binding L.LoadingPasswordDetails}" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
            </StackPanel>
            <StackPanel x:Name="PasswordDetailErrorState"
                        IsVisible="{Binding HasSelectedPasswordDetailsError}"
                        Panel.ZIndex="3"
                        AutomationProperties.Name="{Binding SelectedPasswordDetailsError}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12"
                        Width="300">
                <ic:FluentIcon Icon="Warning" FontSize="30" Foreground="{DynamicResource SystemFillColorCautionBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding SelectedPasswordDetailsError}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <Button x:Name="RetryPasswordDetailsButton"
                        Classes="passwordPrimaryCommand"
                        Command="{Binding RetrySelectedPasswordDetailsCommand}"
                        AutomationProperties.Name="{Binding RetryPasswordDetailsText}"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8"><ic:FluentIcon Icon="ArrowSync" FontSize="17" /><TextBlock Text="{Binding RetryPasswordDetailsText}" /></StackPanel>
                </Button>
            </StackPanel>
            <app:PasswordDetailDialog Margin="16" DataContext="{Binding SelectedPasswordDetails}" ShowHeader="False" IsVisible="{Binding #Root.DataContext.HasCurrentSelectedPasswordDetails}" />
        </Grid>
    </Grid>
</UserControl>
