<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ic="using:FluentIcons.Avalonia"
             xmlns:vm="using:Monica.App.ViewModels"
             x:Class="Monica.App.PasswordDetailDialog"
             x:Name="Root"
             x:DataType="vm:PasswordDetailViewModel"
             mc:Ignorable="d"
             d:DesignWidth="700"
             d:DesignHeight="680">
    <ScrollViewer x:Name="PasswordDetailScrollViewer" VerticalScrollBarVisibility="Auto">
        <StackPanel MinWidth="320" Spacing="14">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" IsVisible="{Binding #Root.ShowHeader}">
                <Border Width="52" Height="52" CornerRadius="26" Background="#2F7DFF">
                    <TextBlock Text="{Binding Initial}" Foreground="White" FontWeight="SemiBold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PasswordDetailGroup">
                        <Expander Header="{Binding Title}" IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Margin="0,0,0,8">
                            <ItemsControl ItemsSource="{Binding VisibleFields}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PasswordDetailField">
                                        <Border Padding="12,10" CornerRadius="0" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" Background="Transparent">
                                            <Grid ColumnDefinitions="132,*,Auto,Auto" ColumnSpacing="8" MinHeight="40">
                                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                <SelectableTextBlock Grid.Column="1" Text="{Binding DisplayText}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                <Button x:Name="PasswordDetailFieldRevealButton"
                                                        Grid.Column="2"
                                                        Command="{Binding #Root.DataContext.ToggleFieldVisibilityCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding CanToggleVisibility}"
                                                        IsVisible="{Binding CanToggleVisibility}"
                                                        ToolTip.Tip="{Binding VisibilityActionLabel}"
                                                        AutomationProperties.Name="{Binding VisibilityActionLabel}">
                                                    <ic:FluentIcon Icon="Eye" FontSize="18" />
                                                </Button>
                                                <Button x:Name="PasswordDetailFieldCopyButton"
                                                        Grid.Column="3"
                                                        Command="{Binding #Root.DataContext.CopyFieldCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding CanCopy}"
                                                        ToolTip.Tip="{Binding #Root.DataContext.CopyLabel}"
                                                        AutomationProperties.Name="{Binding #Root.DataContext.CopyLabel}">
                                                    <ic:FluentIcon Icon="Copy" FontSize="18" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border x:Name="PasswordAttachmentsRegion" Padding="0,14" CornerRadius="0" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" Background="Transparent">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBlock Text="{Binding L.Attachments}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:Name="PasswordAttachmentAddButton"
                                Grid.Column="1"
                                Command="{Binding AddAttachmentCommand}"
                                IsEnabled="{Binding !IsAddingAttachment}"
                                ToolTip.Tip="{Binding AddAttachmentActionLabel}"
                                AutomationProperties.Name="{Binding AddAttachmentActionLabel}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ProgressBar x:Name="PasswordAttachmentAddProgress"
                                             Width="18"
                                             Height="4"
                                             IsIndeterminate="True"
                                             IsVisible="{Binding IsAddingAttachment}"
                                             VerticalAlignment="Center" />
                                <ic:FluentIcon Icon="Attach" FontSize="18" IsVisible="{Binding !IsAddingAttachment}" />
                                <TextBlock Text="{Binding AddAttachmentActionLabel}" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock IsVisible="{Binding !HasAttachments}" Text="{Binding L.NoAttachments}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                    <ItemsControl ItemsSource="{Binding Attachments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PasswordAttachmentItem">
                                <Border Padding="12,10" CornerRadius="0" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10" MinHeight="40">
                                        <ic:FluentIcon Icon="Attach" FontSize="20" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding DisplayValue}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Button x:Name="PasswordAttachmentSaveButton"
                                                Grid.Column="2"
                                                Command="{Binding #Root.DataContext.SaveAttachmentCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{Binding #Root.DataContext.SaveAttachmentLabel}"
                                                AutomationProperties.Name="{Binding #Root.DataContext.SaveAttachmentLabel}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <ic:FluentIcon Icon="Save" FontSize="18" />
                                                <TextBlock Text="{Binding #Root.DataContext.SaveAttachmentLabel}" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="PasswordAttachmentDeleteButton"
                                                Grid.Column="3"
                                                Command="{Binding #Root.DataContext.DeleteAttachmentCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{Binding #Root.DataContext.DeleteLabel}"
                                                AutomationProperties.Name="{Binding #Root.DataContext.DeleteLabel}">
                                            <ic:FluentIcon Icon="Delete" FontSize="18" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border x:Name="PasswordHistoryRegion" IsVisible="{Binding HasPasswordHistory}" Padding="0,14" CornerRadius="0" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" Background="Transparent">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding PasswordHistoryTitle}" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding PasswordHistoryDescription}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding ClearPasswordHistoryCommand}"
                                ToolTip.Tip="{Binding ClearPasswordHistoryLabel}"
                                AutomationProperties.Name="{Binding ClearPasswordHistoryLabel}">
                            <ic:FluentIcon Icon="Delete" FontSize="18" />
                        </Button>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding PasswordHistory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PasswordHistoryItemViewModel">
                                <Border Padding="12,10" CornerRadius="0" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
                                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding LastUsedText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Border IsVisible="{Binding IsLatest}" Padding="8,2" CornerRadius="8" Background="{DynamicResource AccentFillColorDefaultBrush}">
                                                <TextBlock Text="{Binding #Root.DataContext.LatestLabel}" Foreground="White" FontSize="12" />
                                            </Border>
                                        </StackPanel>
                                        <Button x:Name="PasswordHistoryRevealButton"
                                                Grid.Column="1"
                                                Command="{Binding #Root.DataContext.ToggleHistoryPasswordCommand}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding CanCopy}"
                                                ToolTip.Tip="{Binding VisibilityActionLabel}"
                                                AutomationProperties.Name="{Binding VisibilityActionLabel}">
                                            <ic:FluentIcon Icon="Eye" FontSize="18" />
                                        </Button>
                                        <Button x:Name="PasswordHistoryCopyButton"
                                                Grid.Column="2"
                                                Command="{Binding #Root.DataContext.CopyHistoryPasswordCommand}"
                                                CommandParameter="{Binding}"
                                                IsEnabled="{Binding CanCopy}"
                                                ToolTip.Tip="{Binding #Root.DataContext.CopyLabel}"
                                                AutomationProperties.Name="{Binding #Root.DataContext.CopyLabel}">
                                            <ic:FluentIcon Icon="Copy" FontSize="18" />
                                        </Button>
                                        <Button x:Name="PasswordHistoryDeleteButton"
                                                Grid.Column="3"
                                                Command="{Binding #Root.DataContext.DeleteHistoryPasswordCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{Binding #Root.DataContext.DeleteLabel}"
                                                AutomationProperties.Name="{Binding #Root.DataContext.DeleteLabel}">
                                            <ic:FluentIcon Icon="Delete" FontSize="18" />
                                        </Button>
                                        <SelectableTextBlock Grid.Row="1" Grid.ColumnSpan="4" Text="{Binding DisplayPassword}" FontFamily="Consolas" TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
