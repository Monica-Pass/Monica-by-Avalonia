<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="using:FluentAvalonia.UI.Controls"
        xmlns:ic="using:FluentIcons.Avalonia"
        xmlns:local="using:Monica.App"
        xmlns:models="using:Monica.Core.Models"
        xmlns:vm="using:Monica.App.ViewModels"
        xmlns:unlock="using:Monica.App.Features.Unlock"
        xmlns:passwords="using:Monica.App.Features.Passwords"
        xmlns:notes="using:Monica.App.Features.Notes"
        xmlns:authenticator="using:Monica.App.Features.Authenticator"
        xmlns:wallet="using:Monica.App.Features.Wallet"
        xmlns:generator="using:Monica.App.Features.Generator"
        xmlns:archive="using:Monica.App.Features.Archive"
        xmlns:recycleBin="using:Monica.App.Features.RecycleBin"
        xmlns:settings="using:Monica.App.Features.Settings"
        xmlns:sync="using:Monica.App.Features.Sync"
        xmlns:mdbx="using:Monica.App.Features.Mdbx"
        xmlns:timeline="using:Monica.App.Features.Timeline"
        xmlns:databaseManagement="using:Monica.App.Features.DatabaseManagement"
        xmlns:securityAnalysis="using:Monica.App.Features.SecurityAnalysis"
        x:DataType="vm:MainWindowViewModel"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="760"
        x:Class="Monica.App.MainWindow"
        x:Name="Root"
        Title="Monica"
        Icon="/Assets/AppIcon.ico"
        Width="1000"
        Height="650"
        MinWidth="800"
        MinHeight="500"
        KeyDown="MainWindow_OnKeyDown">

    <Window.Styles>
        <StyleInclude Source="/Features/Notes/NoteStyles.axaml" />
        <StyleInclude Source="/Features/Authenticator/AuthenticatorStyles.axaml" />
        <StyleInclude Source="/Features/Wallet/WalletStyles.axaml" />
        <StyleInclude Source="/Features/Generator/GeneratorStyles.axaml" />
        <StyleInclude Source="/Features/Archive/ArchiveStyles.axaml" />
        <StyleInclude Source="/Features/RecycleBin/RecycleBinStyles.axaml" />
        <StyleInclude Source="/Features/Settings/SettingsStyles.axaml" />
        <StyleInclude Source="/Features/Sync/SyncStyles.axaml" />
        <StyleInclude Source="/Features/Mdbx/MdbxStyles.axaml" />
        <StyleInclude Source="/Features/Timeline/TimelineStyles.axaml" />
        <StyleInclude Source="/Features/DatabaseManagement/DatabaseManagementStyles.axaml" />
        <Style Selector="Button.workspaceCommand">
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.workspacePrimaryCommand">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="#101010" />
        </Style>
        <Style Selector="ListBox.workspaceList ListBoxItem">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="54" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="ListBox.workspaceList ListBoxItem:selected">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
        </Style>
        <Style Selector="ListBox.workspaceList ListBoxItem WrapPanel.workspaceRowActions">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="ListBox.workspaceList ListBoxItem:pointerover WrapPanel.workspaceRowActions">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="ListBox.workspaceList ListBoxItem:selected WrapPanel.workspaceRowActions">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="Border.workspaceListRow">
            <Setter Property="Padding" Value="10" />
            <Setter Property="MinHeight" Value="64" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.workspaceListRow.compact">
            <Setter Property="MinHeight" Value="56" />
        </Style>
        <Style Selector="Button.workspaceListRowButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.workspaceListRowButton:pointerover">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.workspaceListRowButton:pressed">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="StackPanel.workspaceEmptyState">
            <Setter Property="Margin" Value="24" />
            <Setter Property="MaxWidth" Value="320" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.workspaceRecoverableStatus">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCautionBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
        </Style>
        <Style Selector="Border.workspacePageHeader">
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="0,0,0,12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="Border.workspacePane">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        </Style>
        <Style Selector="Border.workspaceSidebar">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}" />
        </Style>
        <Style Selector="Border.workspaceStatusChip">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{DynamicResource LayerFillColorSubtleBrush}" />
        </Style>
        <Style Selector="Border.workspaceNavItem">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.workspaceNavItem.accent">
            <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>
        <Style Selector="Button.workspaceNavItem">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.workspaceNavItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundPointerOver}" />
        </Style>
        <Style Selector="Button.workspaceNavItem.accent">
            <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>
        <Style Selector="TextBlock.workspacePageTitle">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBlock.workspacePageSubtitle">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBlock.workspaceSectionLabel">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="TextBlock.workspaceDetailLabel">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="TextBlock.workspaceDetailValue">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,24" Background="{DynamicResource LayerFillColorDefaultBrush}">
        <Grid Grid.Row="0">
            <unlock:UnlockView IsVisible="{Binding !IsUnlocked}" />

            <fa:FANavigationView IsVisible="{Binding IsUnlocked}"
                                 PaneDisplayMode="Left"
                                 IsPaneOpen="False"
                                 IsBackButtonVisible="False"
                                 IsSettingsVisible="False"
                                 OpenPaneLength="240"
                                 Background="{DynamicResource LayerFillColorDefaultBrush}"
                                 SelectionChanged="NavigationView_OnSelectionChanged">
                <fa:FANavigationView.MenuItems>
                    <fa:FANavigationViewItem Content="{Binding L.Passwords}" Tag="Passwords">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Permissions" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.SecureNotes}" Tag="Notes">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="ProtectedDocument" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Totp}" Tag="Totp">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Clock" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Cards}" Tag="Cards">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="ContactInfo" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Generator}" Tag="Generator">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Edit" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Archive}" Tag="Archive">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Library" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.RecycleBin}" Tag="RecycleBin">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Delete" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.SecurityAnalysis}" Tag="SecurityAnalysis">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Permissions" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Timeline}" Tag="Timeline">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Clock" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.MdbxVaults}" Tag="Mdbx">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Folder" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                </fa:FANavigationView.MenuItems>

                <fa:FANavigationView.FooterMenuItems>
                    <fa:FANavigationViewItem Content="{Binding L.DatabaseManagement}" Tag="DatabaseManagement">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Library" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.SyncAndBackup}" Tag="Sync">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Sync" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                    <fa:FANavigationViewItem Content="{Binding L.Settings}" Tag="Settings">
                        <fa:FANavigationViewItem.IconSource>
                            <fa:FASymbolIconSource Symbol="Setting" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </fa:FANavigationViewItem.IconSource>
                    </fa:FANavigationViewItem>
                </fa:FANavigationView.FooterMenuItems>

                <Grid Margin="18" RowDefinitions="Auto,Auto,*" Background="{DynamicResource LayerFillColorDefaultBrush}">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,18" IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsContentHeaderVisible}}">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedSectionTitle}" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Classes="IconButton" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}">
                                <ic:FluentIcon Icon="ArrowClockwise" FontSize="20" />
                            </Button>
                            <Button Classes="IconButton" Command="{Binding ExportDataCommand}" ToolTip.Tip="{Binding L.Export}">
                                <ic:FluentIcon Icon="ArrowDownload" FontSize="20" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Classes="workspaceRecoverableStatus" IsVisible="{Binding HasRecoverableStatusMessage}">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <ic:FluentIcon Icon="Warning" FontSize="18" Foreground="{DynamicResource SystemFillColorCautionBrush}" VerticalAlignment="Top" Margin="0,2,0,0" />
                            <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                            <Button Grid.Column="2" Classes="workspaceCommand" Command="{Binding LoadCommand}" ToolTip.Tip="{Binding L.Refresh}" AutomationProperties.Name="{Binding L.Refresh}" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ic:FluentIcon Icon="ArrowClockwise" FontSize="16" />
                                    <TextBlock Text="{Binding L.Refresh}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <Grid x:Name="WorkspaceHost" Grid.Row="2" SizeChanged="WorkspaceHost_OnSizeChanged">
                        <passwords:PasswordVaultView x:Name="PasswordVaultView"
                                                     IsVisible="{Binding SelectedSection, Converter={x:Static local:StringConverters.IsPasswords}}" />

                        <archive:ArchiveWorkspaceView />

                        <recycleBin:RecycleBinWorkspaceView />


                        <timeline:TimelineWorkspaceView />

                        <securityAnalysis:SecurityAnalysisWorkspaceView />


                        <authenticator:AuthenticatorWorkspaceView />

                        <wallet:WalletWorkspaceView />

                        <settings:SettingsWorkspaceView />



                        <databaseManagement:DatabaseManagementWorkspaceView />

                        <mdbx:MdbxWorkspaceView />

                        <sync:SyncWorkspaceView />

                        <generator:GeneratorWorkspaceView />

                        <notes:NoteWorkspaceView x:Name="NoteWorkspaceView" />
                    </Grid>
                </Grid>
            </fa:FANavigationView>

        </Grid>

        <Border Grid.Row="2"
                IsVisible="{Binding IsUnlocked}"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <Border Padding="10,0" ClipToBounds="True">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Text="Monica" FontSize="12" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="&#xE777;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ShellVaultText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ShellSyncText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <TextBlock Grid.Column="3"
                               Text="{Binding ShellPageText}"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ShellPlatformText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <Border Grid.RowSpan="2"
                IsVisible="{Binding IsLoadingVault}"
                Background="{DynamicResource OverlayFillColorDefaultBrush}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                ClipToBounds="True">
            <StackPanel Width="360"
                        MaxWidth="360"
                        Margin="24"
                        Spacing="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="正在加载保险库"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <TextBlock Text="{Binding VaultLoadStageText}"
                           Foreground="#DDFFFFFF"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
                <ProgressBar IsIndeterminate="True" Height="4" />
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="#C8FFFFFF"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
